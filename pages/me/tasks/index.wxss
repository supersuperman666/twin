.page {
  min-height: 100vh;
  background: #F5F7FB;
  padding: 28rpx 24rpx 48rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-kicker {
  display: block;
  color: #237BE8;
  font-size: 24rpx;
  font-weight: 800;
}

.page-title {
  display: block;
  margin-top: 8rpx;
  color: #16202D;
  font-size: 40rpx;
  font-weight: 900;
}

.page-desc {
  display: block;
  margin-top: 10rpx;
  color: #6D7A89;
  font-size: 25rpx;
  line-height: 1.6;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.summary-card {
  min-height: 126rpx;
  padding: 22rpx 18rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  border: 2rpx solid #E6ECF3;
}

.summary-card.primary {
  border-color: #BBD8FF;
  background: #F1F7FF;
}

.summary-card.warning {
  border-color: #F7D7A1;
  background: #FFF8ED;
}

.summary-card.done {
  border-color: #C6EBDD;
  background: #F1FBF7;
}

.summary-value {
  display: block;
  color: #16202D;
  font-size: 42rpx;
  font-weight: 900;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  color: #6D7A89;
  font-size: 23rpx;
  font-weight: 700;
}

.group-section {
  margin-bottom: 32rpx;
}

.group-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0 4rpx 16rpx;
}

.group-title {
  color: #16202D;
  font-size: 31rpx;
  font-weight: 900;
}

.group-count {
  min-width: 38rpx;
  height: 38rpx;
  line-height: 38rpx;
  border-radius: 19rpx;
  text-align: center;
  color: #237BE8;
  background: #EAF3FF;
  font-size: 23rpx;
  font-weight: 800;
}

.task-card,
.empty-card {
  margin-bottom: 18rpx;
  padding: 26rpx;
  border-radius: 18rpx;
  border: 2rpx solid #E6ECF3;
  background: #FFFFFF;
  box-shadow: 0 10rpx 28rpx rgba(39, 63, 94, 0.05);
}

.active-card {
  border-color: #BBD8FF;
}

.overdue-card {
  border-color: #F7D7A1;
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.time-text {
  display: block;
  color: #7D8896;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.title-text {
  display: block;
  color: #16202D;
  font-size: 30rpx;
  font-weight: 850;
}

.source-text {
  display: block;
  margin-top: 12rpx;
  color: #237BE8;
  font-size: 24rpx;
  font-weight: 750;
}

.summary-text,
.detail-text,
.empty-text {
  display: block;
  color: #566376;
  font-size: 26rpx;
  line-height: 1.6;
}

.summary-text {
  margin-top: 14rpx;
}

.empty-title {
  display: block;
  margin-bottom: 8rpx;
  color: #16202D;
  font-size: 28rpx;
  font-weight: 850;
}

.badge {
  flex: none;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 21rpx;
  line-height: 42rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.badge.active {
  background: #EAF3FF;
  color: #237BE8;
}

.badge.done {
  background: #E9F8F2;
  color: #209C73;
}

.badge.expired {
  background: #FFF2DD;
  color: #C46A00;
}

.expand-body {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #F7FAFD;
}

.detail-label {
  display: block;
  margin-bottom: 10rpx;
  color: #16202D;
  font-size: 24rpx;
  font-weight: 850;
}

.primary-btn,
.secondary-btn {
  width: 100%;
  height: 80rpx;
  margin-top: 22rpx;
  border-radius: 16rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 27rpx;
  font-weight: 850;
}

.primary-btn {
  color: #FFFFFF;
  background: #237BE8;
}

.secondary-btn {
  color: #237BE8;
  background: #EAF3FF;
}
