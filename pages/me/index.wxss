.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 156rpx;
  background: #f6f8fb;
  color: #16202d;
}

.profile-card,
.doctor-card,
.quick-grid,
.simple-card,
.menu-list {
  background: #ffffff;
  border: 1rpx solid #e7ecf2;
  border-radius: 28rpx;
}

.profile-card {
  padding: 30rpx;
  display: grid;
  grid-template-columns: 88rpx 1fr;
  gap: 20rpx;
  align-items: center;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e9f3ff;
  color: #1f82ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 800;
}

.profile-info {
  min-width: 0;
}

.profile-name {
  display: block;
  color: #16202d;
  font-size: 34rpx;
  font-weight: 800;
}

.profile-meta {
  display: block;
  margin-top: 8rpx;
  color: #5d6a7a;
  font-size: 25rpx;
  line-height: 1.35;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #edf2f8;
  color: #5d6a7a;
  font-size: 22rpx;
  font-weight: 600;
}

.doctor-card,
.simple-card {
  margin-top: 20rpx;
  padding: 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.doctor-main {
  min-width: 0;
}

.card-title {
  display: block;
  color: #16202d;
  font-size: 30rpx;
  font-weight: 800;
}

.doctor-name,
.card-value {
  display: block;
  margin-top: 8rpx;
  color: #5d6a7a;
  font-size: 25rpx;
  line-height: 1.4;
}

.chevron {
  color: #8d99a8;
  font-size: 36rpx;
  line-height: 1;
}

.quick-grid {
  margin-top: 20rpx;
  padding: 22rpx 10rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.quick-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #16202d;
  font-size: 24rpx;
  font-weight: 700;
}

.quick-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #e9f3ff;
  color: #1f82ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.link-text {
  flex-shrink: 0;
  color: #1f82ff;
  font-size: 25rpx;
  font-weight: 800;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #16202d;
  font-size: 30rpx;
  font-weight: 800;
}

.menu-list {
  overflow: hidden;
}

.menu-item {
  min-height: 104rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #e7ecf2;
}

.menu-item.compact {
  min-height: 92rpx;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-label {
  display: block;
  color: #16202d;
  font-size: 28rpx;
  font-weight: 700;
}

.menu-desc {
  display: block;
  margin-top: 6rpx;
  color: #8d99a8;
  font-size: 23rpx;
  line-height: 1.35;
}
