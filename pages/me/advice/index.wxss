.page {
  min-height: 100vh;
  background: #EEF2F6;
  padding: 24rpx;
}

.advice-card,
.empty-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #E7ECF2;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #6D7A89;
  font-size: 26rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.time-text {
  display: block;
  color: #7D8896;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.title-text {
  display: block;
  color: #16202D;
  font-size: 30rpx;
  font-weight: 800;
}

.from-text {
  display: block;
  margin-top: 12rpx;
  color: #237BE8;
  font-size: 24rpx;
  font-weight: 700;
}

.summary-text,
.detail-text {
  display: block;
  margin-top: 14rpx;
  color: #425063;
  font-size: 25rpx;
  line-height: 1.6;
}

.badge {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.badge.unread {
  background: #E9F3FF;
  color: #237BE8;
}

.badge.read {
  background: #EDF2F8;
  color: #627084;
}

.expand-body {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #EEF2F6;
}

.detail-block + .detail-block {
  margin-top: 16rpx;
}

.detail-label {
  display: block;
  color: #16202D;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}
