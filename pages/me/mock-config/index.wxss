.page {
  min-height: 100vh;
  padding: 28rpx 30rpx 132rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
}

button::after {
  border: 0;
}

.hero,
.section {
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(40, 82, 126, 0.06);
}

.hero {
  padding: 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #237be8 0%, #17a98a 100%);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.5;
}

.section {
  margin-top: 24rpx;
  padding: 26rpx;
}

.section-head {
  margin-bottom: 18rpx;
  color: #1f2937;
  font-size: 31rpx;
  font-weight: 900;
}

.option-list,
.switch-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.option,
.switch-row {
  min-height: 104rpx;
  padding: 20rpx;
  border: 2rpx solid #e5edf6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.option.active {
  border-color: #237be8;
  background: #eef6ff;
}

.option-title,
.switch-title {
  display: block;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 900;
}

.option-desc,
.switch-desc {
  display: block;
  margin-top: 8rpx;
  color: #7b8794;
  font-size: 23rpx;
  line-height: 1.42;
}

.option-check {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  border-radius: 50%;
  background: #237be8;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
}

.option:not(.active) .option-check {
  background: #d8e2ee;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.primary,
.ghost {
  height: 76rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
}

.primary {
  background: #237be8;
  color: #ffffff;
}

.ghost {
  border: 2rpx solid #d2deeb;
  background: #ffffff;
  color: #4d5d6f;
}
