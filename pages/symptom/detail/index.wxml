<view class="page">
  <view class="hero {{todayStatus.hasDiscomfort === false ? 'green' : ''}}">
    <text class="hero-label">今日状态</text>
    <view class="hero-main">
      <view><text class="hero-value">{{todayStatus.maxSeverity || '--'}}</text></view>
      <text class="hero-badge">{{todayStatus.hasDiscomfort === true ? '有症状' : todayStatus.hasDiscomfort === false ? '无不适' : '暂无记录'}}</text>
    </view>
    <text class="hero-label">{{todayStatus.summary || '暂无今日症状记录'}}</text>
  </view>

  <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="filter-scroll">
    <view class="chips">
      <view wx:for="{{categories}}" wx:key="*this" class="chip {{activeCategory == index ? 'active' : ''}}" data-index="{{index}}" bindtap="selectCategory">{{item}}</view>
    </view>
  </scroll-view>

  <view class="chart-card">
    <view class="chart-head"><text class="chart-title">近7天变化</text><text class="link">症状天数 {{trendSummary.symptomDays}}天</text></view>
    <view class="summary-grid">
      <view class="summary-item"><text class="summary-label">最高程度</text><text class="summary-value">{{trendSummary.maxSeverity}}</text></view>
      <view class="summary-item"><text class="summary-label">呼吸症状</text><text class="summary-value">{{trendSummary.respiratoryDays}}天</text></view>
      <view class="summary-item"><text class="summary-label">睡眠相关</text><text class="summary-value">{{trendSummary.sleepDays}}天</text></view>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">症状记录</text>
    <text class="link" bindtap="goAddSymptom">添加症状</text>
  </view>
  <view wx:for="{{records}}" wx:key="time" class="list-card">
    <view class="list-top">
      <view><text class="list-title">{{item.title}}</text><text class="list-desc">{{item.time}} · {{item.desc}}</text></view>
      <text class="tag {{item.severity_code === 'severe' ? 'danger' : item.severity_code === 'moderate' ? 'warn' : ''}}">{{item.level}}</text>
    </view>
  </view>

  <view wx:if="{{records.length === 0}}" class="empty-state">
    <text class="muted">暂无相关症状记录</text>
  </view>
</view>