.assessment-page {
  min-height: 100vh;
  background: #f6f7f9;
  color: #17212b;
}

.assessment-shell {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #f6f7f9;
}

.assessment-nav {
  height: 112rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-icon {
  width: 56rpx;
  height: 56rpx;
  color: #1f2d3d;
  font-size: 38rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon.close {
  font-size: 44rpx;
  font-weight: 500;
}

.nav-title {
  color: #101928;
  font-size: 34rpx;
  font-weight: 900;
}

.step-header {
  padding: 18rpx 32rpx 24rpx;
  background: #ffffff;
}

.step-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #526070;
  font-size: 24rpx;
  font-weight: 700;
}

.progress-track {
  height: 14rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: #edf0f5;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #237be8;
  transition: width 0.2s ease;
}

.content-scroll {
  height: calc(100vh - 314rpx);
}

.intro {
  padding: 30rpx 32rpx 20rpx;
}

.intro-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.intro-desc {
  display: block;
  margin-top: 8rpx;
  color: #7b8794;
  font-size: 24rpx;
  line-height: 1.45;
}

.question-card {
  margin: 0 32rpx 24rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.compact-card {
  padding: 24rpx 28rpx;
}

.question-title {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 22rpx;
  color: #17212b;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.required {
  color: #ff4d4f;
}

.optional {
  color: #17212b;
  font-size: 26rpx;
  font-weight: 800;
}

.muted {
  display: block;
  color: #8b96a3;
  font-size: 22rpx;
}

.input-box {
  height: 92rpx;
  padding: 0 22rpx;
  border: 2rpx solid #dfe5ec;
  border-radius: 12rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input-box input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  color: #17212b;
  font-size: 28rpx;
  font-weight: 700;
}

.input-box text {
  color: #6b7785;
  font-size: 26rpx;
}

.input-placeholder {
  color: #9aa5b1;
  font-weight: 500;
}

.computed-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.computed-row .question-title {
  margin-bottom: 6rpx;
}

.computed-value {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  color: #237be8;
  font-weight: 900;
}

.computed-value text:first-child {
  font-size: 42rpx;
}

.computed-value text:last-child {
  color: #8b96a3;
  font-size: 22rpx;
}

.segment-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.segment-grid.two {
  grid-template-columns: repeat(2, 1fr);
}

.segment-option {
  min-height: 88rpx;
  padding: 0 14rpx;
  border: 2rpx solid #dfe5ec;
  border-radius: 12rpx;
  color: #526070;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.segment-option text:first-child {
  color: #7b8794;
  font-size: 32rpx;
}

.segment-option.selected {
  border-color: #237be8;
  background: #eef6ff;
  color: #237be8;
}

.segment-option.selected text:first-child {
  color: #237be8;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.grid-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

.option-row,
.check-row {
  min-height: 86rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #e1e7ee;
  border-radius: 12rpx;
  background: #ffffff;
  color: #344054;
  display: flex;
  align-items: center;
  gap: 18rpx;
  text-align: left;
}

.option-row.selected,
.check-row.selected {
  border-color: #237be8;
  background: #f4f9ff;
  color: #237be8;
}

.radio-dot,
.check-box {
  width: 38rpx;
  height: 38rpx;
  flex: 0 0 38rpx;
  border: 3rpx solid #cbd3dd;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.radio-dot {
  border-radius: 50%;
}

.check-box {
  border-radius: 8rpx;
}

.option-row.selected .radio-dot {
  border-color: #237be8;
  box-shadow: inset 0 0 0 8rpx #ffffff;
  background: #237be8;
}

.check-row.selected .check-box {
  border-color: #237be8;
  background: #237be8;
}

.option-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.option-copy text:first-child {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
}

.option-copy text:last-child {
  color: #8b96a3;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.35;
}

.option-row.selected .option-copy text:last-child,
.check-row.selected .option-copy text:last-child {
  color: #5d95dd;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f0f3f7;
  color: #344054;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.tag-option.selected {
  background: #dcebff;
  color: #237be8;
  font-weight: 900;
}

.textarea-box {
  margin-top: 18rpx;
  border: 2rpx solid #dfe5ec;
  border-radius: 12rpx;
  background: #fafbfc;
}

.textarea-box textarea {
  width: 100%;
  min-height: 132rpx;
  padding: 18rpx 20rpx;
  color: #17212b;
  font-size: 26rpx;
  box-sizing: border-box;
}

.rating-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 4rpx 20rpx 0;
}

.star {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #f0f3f7;
  color: #9aa5b1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.star.selected {
  background: #fff6d9;
  color: #f6bd16;
}

.rating-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  color: #8b96a3;
  font-size: 22rpx;
}

.rating-labels text:nth-child(2) {
  color: #f59f00;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx 28rpx;
  background: #f6f7f9;
  display: flex;
  gap: 20rpx;
}

.ghost-btn,
.primary-btn {
  height: 92rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
}

.ghost-btn {
  width: 230rpx;
  border: 2rpx solid #dfe5ec;
  background: #ffffff;
  color: #344054;
}

.primary-btn {
  flex: 1;
  background: #237be8;
  color: #ffffff;
}

.primary-btn.disabled {
  background: #cfd6df;
}

.result-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
  background: #f5f7fb;
}

.result-hero {
  padding: 38rpx 30rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f88ef 0%, #237be8 58%, #66b4f4 100%);
  box-shadow: 0 18rpx 44rpx rgba(42, 121, 215, 0.2);
}

.result-kicker,
.result-title,
.result-desc {
  display: block;
}

.result-kicker {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  font-weight: 800;
}

.result-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.score-ring {
  width: 184rpx;
  height: 184rpx;
  margin: 30rpx auto;
  border: 12rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
}

.score {
  font-size: 54rpx;
  font-weight: 900;
}

.score-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
}

.result-risk-pill {
  width: 132rpx;
  margin: 0 auto 24rpx;
  padding: 10rpx 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
}

.result-desc {
  font-size: 26rpx;
  line-height: 1.55;
}

.result-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(40, 82, 126, 0.07);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: #8a96a3;
  font-size: 24rpx;
  font-weight: 800;
}

.card-head text:first-child {
  color: #17212b;
  font-size: 32rpx;
  font-weight: 900;
}

.abnormal-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1f6;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.abnormal-item:last-child {
  border-bottom: 0;
}

.abnormal-name,
.abnormal-desc {
  display: block;
}

.abnormal-name {
  color: #273444;
  font-size: 28rpx;
  font-weight: 900;
}

.abnormal-desc {
  margin-top: 8rpx;
  color: #6b7785;
  font-size: 24rpx;
  line-height: 1.4;
}

.abnormal-score {
  color: #ff7a45;
  font-size: 28rpx;
  font-weight: 900;
}

.empty-state {
  padding: 28rpx 0;
  color: #6b7785;
  font-size: 26rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.outline-btn,
.solid-btn {
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
}

.outline-btn {
  border: 2rpx solid #237be8;
  color: #237be8;
  background: #ffffff;
}

.solid-btn {
  background: #237be8;
  color: #ffffff;
}
