.assessment-page {
  min-height: 100vh;
  background: #f3f6fb;
  color: #1f2937;
}

.assessment-shell {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #f3f6fb;
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
}

button::after {
  border: 0;
}

.assessment-nav {
  min-height: 88rpx;
  padding-left: 18rpx;
  padding-right: 190rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e7edf5;
  display: grid;
  grid-template-columns: 56rpx 1fr;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 0;
  background: transparent;
  color: #3d4a5c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.nav-icon.close {
  display: none;
}

.nav-copy {
  min-width: 0;
  text-align: center;
}

.nav-title {
  display: block;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.nav-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #8693a3;
  font-size: 21rpx;
}

.step-header {
  padding: 16rpx 28rpx 18rpx;
  background: #ffffff;
}

.step-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #5f6f82;
  font-size: 24rpx;
  font-weight: 800;
}

.step-meta text:last-child {
  color: #1296f7;
}

.progress-track {
  height: 9rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #e8edf5;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #1296f7;
  transition: width 0.2s ease;
}

.content-scroll {
  height: calc(100vh - 242rpx);
}

.intro {
  margin: 18rpx 28rpx 16rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #d7eaff;
  border-left: 8rpx solid #1296f7;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2937;
  box-shadow: 0 6rpx 18rpx rgba(41, 74, 110, 0.05);
}

.intro-kicker {
  display: block;
  margin-bottom: 8rpx;
  color: #1296f7;
  font-size: 23rpx;
  font-weight: 900;
}

.intro-title {
  display: block;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.intro-desc {
  display: block;
  margin-top: 8rpx;
  color: #66758a;
  font-size: 25rpx;
  line-height: 1.42;
}

.intro-foot {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #edf2f7;
  color: #8a96a6;
  font-size: 22rpx;
  font-weight: 800;
}

.section-title {
  margin: 28rpx 28rpx 16rpx;
  color: #5f6f82;
  font-size: 24rpx;
  font-weight: 900;
}

.question-card {
  margin: 0 28rpx 20rpx;
  padding: 26rpx 24rpx;
  border: 1rpx solid #e1e8f0;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(41, 74, 110, 0.05);
  box-sizing: border-box;
}

.compact-card {
  padding: 24rpx 28rpx;
}

.question-title {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 18rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.36;
}

.required {
  color: #d54941;
}

.optional {
  color: #8a96a6;
  font-size: 24rpx;
  font-weight: 700;
}

.muted {
  display: block;
  color: #8a96a6;
  font-size: 23rpx;
  line-height: 1.42;
}

.input-box {
  height: 88rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8e1ec;
  border-radius: 14rpx;
  background: #f9fbfd;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input-box:focus-within {
  border-color: #1296f7;
}

.input-box input {
  flex: 1;
  min-width: 0;
  height: 86rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.input-box text {
  color: #66758a;
  font-size: 25rpx;
  font-weight: 800;
}

.input-placeholder {
  color: #a2acb9;
  font-weight: 500;
}

.computed-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.computed-row .question-title {
  margin-bottom: 6rpx;
}

.computed-value {
  min-width: 148rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #eaf7ff;
  color: #1296f7;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  font-weight: 900;
}

.computed-value text:first-child {
  font-size: 40rpx;
}

.computed-value text:last-child {
  color: #66758a;
  font-size: 21rpx;
}

.segment-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.segment-grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.segment-option {
  width: 100%;
  min-height: 84rpx;
  padding: 0 14rpx;
  border: 1rpx solid #d8e1ec;
  border-radius: 14rpx;
  color: #3d4a5c;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 27rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.segment-option text:first-child {
  color: #66758a;
  font-size: 31rpx;
}

.segment-option.selected {
  border-color: #1296f7;
  background: #eaf7ff;
  color: #1296f7;
}

.segment-option.selected text:first-child {
  color: #1296f7;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 100%;
}

.grid-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.option-row,
.check-row {
  width: 100%;
  margin-left: 0;
  margin-right: 0;
  min-height: 78rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #d8e1ec;
  border-radius: 14rpx;
  background: #ffffff;
  color: #344054;
  display: flex;
  align-items: center;
  gap: 18rpx;
  text-align: left;
  justify-content: flex-start;
  box-sizing: border-box;
  line-height: 1.3;
}

.option-row.selected,
.check-row.selected {
  border-color: #1296f7;
  background: #f2f7ff;
  color: #1296f7;
}

.radio-dot,
.check-box {
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 34rpx;
  border: 2rpx solid #c5cfdd;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.radio-dot {
  border-radius: 50%;
}

.check-box {
  border-radius: 8rpx;
}

.option-row.selected .radio-dot {
  border-color: #1296f7;
  box-shadow: inset 0 0 0 8rpx #ffffff;
  background: #1296f7;
}

.check-row.selected .check-box {
  border-color: #1296f7;
  background: #1296f7;
}

.option-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  align-items: flex-start;
}

.option-copy text:first-child {
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: left;
}

.option-copy text:last-child {
  color: #8a96a6;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.35;
}

.option-row.selected .option-copy text:last-child,
.check-row.selected .option-copy text:last-child {
  color: #3aaaf8;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-option {
  max-width: 100%;
  min-height: 58rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8e1ec;
  border-radius: 999rpx;
  background: #ffffff;
  color: #344054;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.tag-option.selected {
  border-color: #1296f7;
  background: #eaf7ff;
  color: #1296f7;
}

.textarea-box {
  margin-top: 18rpx;
  border: 1rpx solid #d8e1ec;
  border-radius: 14rpx;
  background: #f9fbfd;
}

.textarea-box textarea {
  width: 100%;
  min-height: 132rpx;
  padding: 18rpx 20rpx;
  color: #111827;
  font-size: 26rpx;
  box-sizing: border-box;
}

.rating-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14rpx;
}

.star {
  height: 72rpx;
  border: 1rpx solid #d8e1ec;
  border-radius: 14rpx;
  background: #ffffff;
  color: #a2acb9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.star.selected {
  border-color: #f5ba18;
  background: #fff8e1;
  color: #f5ba18;
}

.rating-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  color: #8a96a6;
  font-size: 22rpx;
}

.rating-labels text:nth-child(2) {
  color: #c87800;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 28rpx calc(env(safe-area-inset-bottom) + 18rpx);
  border-top: 1rpx solid #dfe7f0;
  background: rgba(243, 246, 251, 0.96);
  backdrop-filter: blur(10px);
  display: flex;
  gap: 16rpx;
}

.ghost-btn,
.primary-btn,
.outline-btn,
.solid-btn {
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.ghost-btn {
  width: 210rpx;
  border: 1rpx solid #d8e1ec;
  background: #ffffff;
  color: #3d4a5c;
}

.primary-btn {
  flex: 1;
  background: #1296f7;
  color: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(18, 150, 247, 0.2);
}

.primary-btn.disabled {
  background: #c6d0dd;
  box-shadow: none;
}

.result-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
  background: #f3f6fb;
  box-sizing: border-box;
}

.result-hero {
  padding: 32rpx 30rpx;
  border-radius: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1296f7 0%, #0d8fe8 58%, #10a77d 100%);
  box-shadow: 0 18rpx 44rpx rgba(18, 150, 247, 0.2);
}

.result-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.result-kicker,
.result-title,
.result-desc {
  display: block;
}

.result-kicker {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 900;
}

.result-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.22;
}

.score-ring {
  width: 148rpx;
  height: 148rpx;
  flex: 0 0 148rpx;
  border: 10rpx solid rgba(255, 255, 255, 0.56);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.score {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.score-label {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 20rpx;
  font-weight: 800;
}

.result-risk-pill {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
}

.result-desc {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.55;
}

.result-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #e1e8f0;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(41, 74, 110, 0.06);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  color: #8a96a6;
  font-size: 24rpx;
  font-weight: 800;
}

.card-head text:first-child {
  color: #111827;
  font-size: 31rpx;
  font-weight: 900;
}

.abnormal-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #edf1f6;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.abnormal-item:last-child {
  border-bottom: 0;
}

.abnormal-name,
.abnormal-desc {
  display: block;
}

.abnormal-name {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 900;
}

.abnormal-desc {
  margin-top: 8rpx;
  color: #6b7788;
  font-size: 24rpx;
  line-height: 1.42;
}

.abnormal-score {
  color: #e37318;
  font-size: 28rpx;
  font-weight: 900;
}

.empty-state {
  padding: 28rpx 0;
  color: #6b7788;
  font-size: 26rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 26rpx;
}

.outline-btn {
  border: 1rpx solid #1296f7;
  color: #1296f7;
  background: #ffffff;
}

.solid-btn {
  background: #1296f7;
  color: #ffffff;
}
