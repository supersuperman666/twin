.page {
  min-height: 100vh;
  padding: 0 28rpx 132rpx;
  background: #f5f7fb;
}

.top-area {
  margin: 0 -28rpx;
  padding: 24rpx 28rpx 32rpx;
  background: linear-gradient(180deg, #4b92f0 0%, #66b4f4 62%, #f5f7fb 100%);
}

.stage-switch {
  display: flex;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.24);
}

.stage-switch button {
  flex: 1;
  height: 58rpx;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.stage-switch button.active {
  background: #ffffff;
  color: #237be8;
  box-shadow: 0 8rpx 20rpx rgba(65, 128, 212, 0.16);
}

.hero {
  padding: 28rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f88ef 0%, #20b6d3 52%, #16b889 100%);
  box-shadow: 0 18rpx 40rpx rgba(42, 121, 215, 0.22);
}

.hero-new {
  background: linear-gradient(135deg, #2f88ef 0%, #16b889 100%);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.greeting {
  min-width: 0;
  flex: 1;
}

.hero-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.16;
}

.hero-desc {
  display: block;
  color: rgba(255, 255, 255, 0.9);
  font-size: 25rpx;
  line-height: 1.42;
}

.risk-badge {
  width: 142rpx;
  height: 142rpx;
  flex: 0 0 142rpx;
  padding: 7rpx;
  border: 10rpx solid #fff1b8;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
}

.risk-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(20, 148, 178, 0.86);
}

.risk-title {
  font-size: 28rpx;
  font-weight: 900;
}

.risk-label {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 19rpx;
}

.hero-note {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.13);
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-metrics,
.screening-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.metric,
.screening-grid view {
  min-width: 0;
  padding: 16rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.12);
}

.metric text:first-child,
.screening-grid text:first-child {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 21rpx;
}

.metric .value {
  font-size: 31rpx;
  font-weight: 900;
}

.screening-grid text:last-child {
  display: block;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
}

.warn {
  margin-left: 6rpx;
  color: #fff0b8;
  font-size: 21rpx;
  font-weight: 900;
}

.primary-btn {
  height: 72rpx;
  margin-top: 22rpx;
  border-radius: 36rpx;
  background: #ffffff;
  color: #237be8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
}

.assessed-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.assessed-actions .primary-btn {
  margin-top: 0;
}

.primary-btn.inline,
.secondary-btn {
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
}

.secondary-btn {
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  color: #ffffff;
  background: rgba(255, 255, 255, 0.1);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 4rpx 18rpx;
}

.section-head text {
  font-size: 32rpx;
  font-weight: 900;
}

.section-head button {
  color: #237be8;
  font-size: 26rpx;
  font-weight: 800;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.service-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick,
.service {
  height: 130rpx;
  border: 1rpx solid #e4ebf3;
  border-radius: 16rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 8rpx 22rpx rgba(40, 82, 126, 0.07);
}

.quick {
  height: 132rpx;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.quick-icon,
.service view {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #d9eaff;
  color: #0f7df2;
}

.quick text,
.service text {
  font-size: 24rpx;
  font-weight: 800;
}

.quick text {
  color: #273444;
  font-size: 27rpx;
  font-weight: 900;
}

.css-icon {
  position: relative;
  color: #0f7df2;
}

.glucose-icon {
  width: 30rpx;
  height: 40rpx;
  border: 6rpx solid currentColor;
  border-radius: 22rpx 22rpx 24rpx 24rpx;
  transform: rotate(45deg);
}

.glucose-icon::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 6rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.heart-icon {
  width: 42rpx;
  height: 36rpx;
  transform: rotate(-45deg);
}

.heart-icon::before,
.heart-icon::after {
  content: "";
  position: absolute;
  border: 6rpx solid currentColor;
  background: transparent;
}

.heart-icon::before {
  width: 24rpx;
  height: 36rpx;
  left: 9rpx;
  top: 0;
  border-left-color: transparent;
  border-bottom-color: transparent;
  border-radius: 26rpx 26rpx 0 0;
}

.heart-icon::after {
  width: 36rpx;
  height: 24rpx;
  left: 0;
  top: 10rpx;
  border-right-color: transparent;
  border-bottom-color: transparent;
  border-radius: 26rpx 0 0 26rpx;
}

.pulse-line {
  position: absolute;
  left: 7rpx;
  top: 18rpx;
  z-index: 2;
  width: 34rpx;
  height: 16rpx;
  border-left: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  transform: rotate(45deg);
}

.pressure-dot {
  position: absolute;
  right: -5rpx;
  bottom: -1rpx;
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: currentColor;
}

.moon-icon {
  width: 42rpx;
  height: 42rpx;
  border: 7rpx solid currentColor;
  border-top-color: transparent;
  border-right-color: transparent;
  border-radius: 50%;
  transform: rotate(-35deg);
}

.pill-icon {
  width: 42rpx;
  height: 24rpx;
  border: 6rpx solid currentColor;
  border-radius: 999rpx;
  transform: rotate(-35deg);
}

.pill-icon view {
  position: absolute;
  left: 16rpx;
  top: -6rpx;
  width: 6rpx;
  height: 24rpx;
  background: currentColor;
}

.alert-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.alert {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  border: 1rpx solid #e4ebf3;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(40, 82, 126, 0.07);
}

.alert.high {
  border-color: rgba(243, 92, 106, 0.28);
  background: #fff7f8;
}

.alert.medium {
  border-color: rgba(237, 158, 40, 0.25);
  background: #fffaf0;
}

.alert-mark {
  width: 60rpx;
  height: 60rpx;
  flex: 0 0 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 900;
}

.alert.high .alert-mark {
  background: #f35c6a;
}

.alert.medium .alert-mark {
  background: #ed9e28;
}

.alert-content {
  flex: 1;
  min-width: 0;
}

.alert-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.32;
}

.alert-desc {
  display: block;
  color: #6b7785;
  font-size: 24rpx;
  line-height: 1.48;
}

.alert button,
.task button {
  height: 54rpx;
  min-width: 116rpx;
  border-radius: 28rpx;
  background: #e8f2ff;
  color: #237be8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.task-panel,
.drug-card,
.plan-card,
.profile-card {
  padding: 24rpx;
  border: 1rpx solid #e4ebf3;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(40, 82, 126, 0.07);
}

.task {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #edf2f7;
}

.task:last-child {
  border-bottom: 0;
}

.task-index {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2d8df0;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.task-index.done {
  background: #dce6f1;
  color: #7b8a9a;
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.task-desc {
  display: block;
  color: #6b7785;
  font-size: 24rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.card-title {
  display: block;
  margin-bottom: 10rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.card-desc {
  display: block;
  color: #6b7785;
  font-size: 24rpx;
  line-height: 1.5;
}

.pill {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #e8f2ff;
  color: #237be8;
  font-size: 22rpx;
  font-weight: 900;
}

.drug-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
}

.drug-list view {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #f6f9fd;
}

.drug-list text:first-child {
  font-size: 26rpx;
  font-weight: 900;
}

.drug-list text:last-child {
  color: #6b7785;
  font-size: 24rpx;
}

.progress {
  height: 16rpx;
  margin: 24rpx 0 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e4edf8;
}

.progress view {
  width: 62%;
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4b92f0, #37c4b4);
}

.plan-meta {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.plan-meta view {
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: #f6f9fd;
}

.plan-meta text:first-child {
  display: block;
  margin-bottom: 8rpx;
  color: #6b7785;
  font-size: 22rpx;
}

.plan-meta text:last-child {
  font-size: 26rpx;
  font-weight: 900;
}

.profile-card {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.profile-card text {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #506172;
  font-size: 24rpx;
  font-weight: 800;
}

.module-card {
  margin-top: 30rpx;
  padding: 30rpx 28rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(39, 63, 94, 0.06);
}

.module-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.title-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #1d2733;
  font-size: 34rpx;
  font-weight: 900;
}

.title-icon,
.title-symbol {
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 32rpx;
}

.title-icon {
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.warn-icon {
  border: 4rpx solid #ff4d5c;
  border-radius: 50%;
  color: #ff4d5c;
}

.title-symbol {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.alert-symbol {
  color: #ff4d5c;
  border: 4rpx solid #ff4d5c;
}

.calendar-symbol {
  position: relative;
  border: 4rpx solid #277cf6;
  border-radius: 7rpx;
}

.calendar-symbol::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: 7rpx;
  height: 4rpx;
  background: #277cf6;
}

.calendar-icon {
  border: 4rpx solid #277cf6;
  color: #277cf6;
}

.module-extra {
  color: #687586;
  font-size: 28rpx;
}

.risk-module {
  margin-top: 32rpx;
  padding-bottom: 28rpx;
}

.risk-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 26rpx 22rpx 28rpx;
  border-radius: 16rpx;
}

.risk-item + .risk-item {
  margin-top: 20rpx;
}

.high-risk {
  background: #fff0f1;
  color: #dc2f3a;
}

.medium-risk {
  background: #fff7eb;
  color: #b95608;
}

.risk-level {
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 46rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  margin-top: 4rpx;
}

.high-risk .risk-level {
  background: #f14150;
}

.medium-risk .risk-level {
  background: #ff861b;
}

.risk-body {
  flex: 1;
  min-width: 0;
}

.risk-body .risk-title {
  display: block;
  margin-bottom: 8rpx;
  color: inherit;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.32;
}

.risk-desc {
  display: block;
  color: inherit;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.42;
}

.risk-body button {
  width: 176rpx;
  height: 50rpx;
  margin-top: 18rpx;
  margin-left: 0;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  font-size: 23rpx;
  font-weight: 900;
}

.high-risk button {
  background: #ffdfe2;
  color: #dc2f3a;
}

.medium-risk button {
  background: #ffebcf;
  color: #b95608;
}

.todo-item {
  min-height: 112rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f8fafc;
}

.todo-item + .todo-item {
  margin-top: 18rpx;
}

.todo-item.pending {
  background: #edf6ff;
}

.todo-status {
  width: 54rpx;
  height: 54rpx;
  flex: 0 0 54rpx;
  border: 4rpx solid #1fc76a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1fc76a;
  font-size: 26rpx;
  font-weight: 900;
}

.todo-item.pending .todo-status {
  border-color: #277cf6;
  color: #277cf6;
}

.todo-info {
  flex: 1;
  min-width: 0;
}

.todo-title {
  display: block;
  margin-bottom: 8rpx;
  color: #263442;
  font-size: 30rpx;
  font-weight: 900;
}

.todo-desc {
  display: block;
  color: #738091;
  font-size: 26rpx;
  line-height: 1.35;
}

.todo-value {
  flex: 0 0 auto;
  color: #00a978;
  font-size: 28rpx;
  font-weight: 900;
}

.todo-item button {
  width: 116rpx;
  height: 54rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #227cf6;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.medicine-module .module-title {
  margin-bottom: 24rpx;
}

.medicine-item {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.medicine-item + .medicine-item {
  margin-top: 18rpx;
}

.medicine-icon {
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 70rpx;
  border-radius: 50%;
  background: #dbeaff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.medicine-icon.active {
  color: #276ff0;
  font-size: 34rpx;
  font-weight: 900;
}

.capsule-symbol {
  width: 38rpx;
  height: 18rpx;
  border: 5rpx solid currentColor;
  border-radius: 18rpx;
  transform: rotate(-28deg);
  box-sizing: border-box;
}

.capsule-symbol.muted {
  opacity: 0.52;
}

.medicine-info {
  flex: 1;
  min-width: 0;
}

.medicine-name {
  display: block;
  color: #253241;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.medicine-desc {
  display: block;
  margin-top: 6rpx;
  color: #7a8492;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}

.medicine-note {
  display: block;
  margin-top: 6rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.medicine-note.success {
  color: #00a978;
}

.medicine-note.warning {
  color: #ed7c12;
}

.medicine-tag {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.medicine-tag.taken {
  background: #dff7ea;
  color: #108a54;
}

.medicine-tag.waiting {
  background: #ffead0;
  color: #bf650e;
}

.doctor-advice {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  display: flex;
  gap: 18rpx;
  background: #eaf4ff;
  color: #1f5fbf;
}

.doctor-icon {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
  border-radius: 50%;
  background: #d8eaff;
  color: #1f5fbf;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.advice-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.advice-desc {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.42;
}

.follow-module .module-title button {
  color: #227cf6;
  font-size: 26rpx;
  font-weight: 900;
}

.follow-next {
  padding: 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #eaf4ff;
}

.date-box {
  width: 78rpx;
  height: 96rpx;
  flex: 0 0 78rpx;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #247cf6;
  color: #ffffff;
  font-weight: 900;
}

.date-box text:first-child {
  font-size: 24rpx;
}

