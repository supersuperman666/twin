.page {
  min-height: 100vh;
  padding: 0 28rpx 132rpx;
  background: #f4f7fb;
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
}

button::after {
  border: 0;
}

.status-card {
  margin-top: 18rpx;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2478f2 0%, #16a6c8 52%, #17a77a 100%);
  box-shadow: 0 18rpx 42rpx rgba(40, 111, 203, 0.22);
}

.status-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.status-copy {
  min-width: 0;
  flex: 1;
}

.status-kicker,
.module-kicker {
  display: block;
  margin-bottom: 8rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.status-kicker {
  color: rgba(255, 255, 255, 0.78);
}

.status-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
}

.status-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 25rpx;
  line-height: 1.42;
}

.score-ring {
  width: 134rpx;
  height: 134rpx;
  flex: 0 0 134rpx;
  border: 9rpx solid rgba(255, 235, 160, 0.94);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.score-value {
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.score-label {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 20rpx;
  font-weight: 800;
}

.status-foot {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.22);
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  font-weight: 800;
}

.status-foot text {
  min-width: 0;
}

.indicator-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.indicator-card {
  min-height: 118rpx;
  padding: 16rpx 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 8rpx 18rpx rgba(23, 83, 135, 0.12);
  box-sizing: border-box;
}

.indicator-card.warning {
  border-color: #ffe1b8;
}

.indicator-card.danger {
  border-color: #ffd1d8;
}

.indicator-card.info {
  border-color: #d7e8ff;
}

.indicator-card.good {
  border-color: #d1fae5;
}

.indicator-card.gray {
  border-color: #e5e7eb;
}

.indicator-top {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.indicator-label {
  color: #526171;
  font-size: 23rpx;
  font-weight: 800;
}

.indicator-status,
.risk-tag,
.method-tag,
.plan-status,
.device-state {
  flex: 0 0 auto;
  padding: 6rpx 11rpx;
  border-radius: 999rpx;
  background: #fff1d8;
  color: #b85c00;
  font-size: 19rpx;
  font-weight: 900;
}

.indicator-card.danger .indicator-status,
.risk-tag,
.device-state.warn {
  background: #ffe5e8;
  color: #d9303f;
}

.indicator-card.info .indicator-status {
  background: #e9f3ff;
  color: #237be8;
}

.indicator-card.good .indicator-status {
  background: #e2f8ef;
  color: #0ca66f;
}

.indicator-card.gray .indicator-status {
  background: #f0f2f5;
  color: #667085;
}

.indicator-value-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  margin-top: 12rpx;
}

.indicator-value {
  color: #1d2733;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.indicator-unit {
  color: #6f7d8c;
  font-size: 19rpx;
  font-weight: 800;
}

.indicator-meta {
  display: block;
  margin-top: 7rpx;
  color: #7d8997;
  font-size: 21rpx;
  font-weight: 700;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 32rpx 4rpx 18rpx;
}

.section-head.compact {
  margin-top: 26rpx;
}

.section-head text {
  color: #1d2733;
  font-size: 32rpx;
  font-weight: 900;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}

.quick {
  min-width: 0;
  height: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.quick-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  background: #e5f1ff;
  color: #1478eb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick text {
  color: #243244;
  font-size: 24rpx;
  font-weight: 900;
}

.css-icon {
  position: relative;
  color: currentColor;
}

.glucose-icon {
  width: 28rpx;
  height: 38rpx;
  border: 6rpx solid currentColor;
  border-radius: 22rpx 22rpx 24rpx 24rpx;
  transform: rotate(45deg);
}

.glucose-icon::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 6rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.pressure-mini {
  width: 42rpx;
  height: 30rpx;
  border: 6rpx solid currentColor;
  border-top-left-radius: 22rpx;
  border-top-right-radius: 22rpx;
  border-bottom: 0;
}

.pressure-mini::after {
  content: "";
  position: absolute;
  left: 16rpx;
  top: 10rpx;
  width: 6rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: rotate(28deg);
}

.pill-icon {
  width: 42rpx;
  height: 24rpx;
  border: 6rpx solid currentColor;
  border-radius: 999rpx;
  transform: rotate(-35deg);
}

.pill-icon view {
  position: absolute;
  left: 16rpx;
  top: -6rpx;
  width: 6rpx;
  height: 24rpx;
  background: currentColor;
}

.symptom-icon {
  width: 42rpx;
  height: 42rpx;
  border: 6rpx solid currentColor;
  border-radius: 50%;
}

.symptom-icon::before,
.symptom-icon::after {
  content: "";
  position: absolute;
  left: 16rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.symptom-icon::before {
  top: 8rpx;
  height: 16rpx;
}

.symptom-icon::after {
  bottom: 7rpx;
  height: 7rpx;
}

.more-icon {
  width: 44rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.more-icon::before,
.more-icon::after {
  content: "";
  position: absolute;
  top: 0;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.more-icon::before {
  left: -16rpx;
}

.more-icon::after {
  right: -16rpx;
}

.new-home {
  padding-top: 18rpx;
}

.assessed-home {
  padding-top: 18rpx;
}

.screening-card {
  padding: 30rpx 28rpx;
  border-radius: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #237be8 0%, #17a98a 100%);
  box-shadow: 0 18rpx 42rpx rgba(40, 111, 203, 0.2);
}

.result-card {
  padding: 30rpx 28rpx;
  border-radius: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #245ee8 0%, #2a9fd8 52%, #17a98a 100%);
  box-shadow: 0 18rpx 42rpx rgba(40, 111, 203, 0.2);
}

.risk-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.risk-chip {
  padding: 16rpx 18rpx;
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.risk-chip text:first-child {
  display: block;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  font-weight: 800;
}

.risk-chip text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.result-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.result-actions .screening-btn {
  margin-top: 0;
}

.outline-btn {
  height: 74rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.screening-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.screening-status {
  display: block;
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
  font-weight: 900;
}

.screening-title {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
}

.screening-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.45;
}

.screening-badge {
  width: 96rpx;
  height: 96rpx;
  flex: 0 0 96rpx;
  border: 8rpx solid rgba(255, 238, 166, 0.95);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.screening-note {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.42;
}

.screening-btn {
  height: 74rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #237be8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.new-module {
  margin-top: 24rpx;
  padding: 26rpx;
  border: 1rpx solid #e2eaf3;
  border-radius: 20rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(40, 82, 126, 0.06);
  box-sizing: border-box;
}

.new-module-copy {
  min-width: 0;
  flex: 1;
}

.new-module-title {
  display: block;
  color: #1d2733;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.new-module-desc {
  display: block;
  margin-top: 8rpx;
  color: #5f6f82;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.42;
}

.new-module-note {
  display: block;
  margin-top: 8rpx;
  color: #8a96a3;
  font-size: 23rpx;
  line-height: 1.4;
}

.new-module-action {
  width: 174rpx;
  height: 60rpx;
  flex: 0 0 174rpx;
  border-radius: 999rpx;
  background: #e8f2ff;
  color: #237be8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.profile-progress {
  width: 116rpx;
  flex: 0 0 116rpx;
}

.profile-progress text {
  display: block;
  margin-bottom: 10rpx;
  color: #237be8;
  text-align: right;
  font-size: 30rpx;
  font-weight: 900;
}

.profile-progress > view {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dce8f7;
}

.profile-progress > view > view {
  height: 100%;
  border-radius: 999rpx;
  background: #237be8;
}

.oxygen-icon {
  width: 42rpx;
  height: 42rpx;
  border: 6rpx solid currentColor;
  border-radius: 50%;
}

.oxygen-icon::after {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 12rpx;
  width: 18rpx;
  height: 10rpx;
  border-left: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  transform: rotate(-35deg);
}

.bottom-note {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 16rpx;
  background: #eef4fb;
  color: #677789;
  font-size: 23rpx;
  line-height: 1.48;
}

.module-card,
.placeholder-card {
  margin-top: 26rpx;
  padding: 28rpx;
  border: 1rpx solid #e2eaf3;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(40, 82, 126, 0.06);
  box-sizing: border-box;
}

.risk-card {
  border-color: #ffd4da;
  background: #fff8f9;
}

.doctor-card {
  background: #f3f8ff;
}

.module-title {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.module-title.tight {
  margin-bottom: 14rpx;
}

.module-kicker {
  color: #6e7b8b;
}

.module-heading {
  display: block;
  color: #1d2733;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.3;
}

.module-desc {
  display: block;
  color: #5e6c7d;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.52;
}

.two-line {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
}

.card-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.primary-action,
.ghost-action,
.link-btn,
.todo-action {
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1;
}

.primary-action {
  min-width: 156rpx;
  padding: 0 26rpx;
  background: #227cf6;
  color: #ffffff;
}

.ghost-action {
  min-width: 156rpx;
  padding: 0 26rpx;
  border: 1rpx solid #d4e1ef;
  background: #ffffff;
  color: #227cf6;
}

.link-btn {
  height: 52rpx;
  padding: 0 4rpx 0 18rpx;
  color: #227cf6;
  background: transparent;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.todo-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 94rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  box-sizing: border-box;
}

.todo-row.done {
  background: #f6faf8;
}

.todo-dot {
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 46rpx;
  border: 4rpx solid #2478f2;
  border-radius: 50%;
  color: #18a66f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.todo-row.done .todo-dot {
  border-color: #18a66f;
  background: #e3f7ee;
}

.todo-info {
  min-width: 0;
  flex: 1;
}

.todo-title {
  display: block;
  color: #223044;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.32;
}

.todo-meta {
  display: block;
  margin-top: 6rpx;
  color: #7a8796;
  font-size: 23rpx;
  font-weight: 700;
}

.todo-action {
  flex: 0 0 auto;
  min-width: 112rpx;
  padding: 0 20rpx;
  background: #e7f1ff;
  color: #227cf6;
}

.done-label {
  flex: 0 0 auto;
  color: #18a66f;
  font-size: 23rpx;
  font-weight: 900;
}

.doctor-name,
.method-tag {
  background: #e7f1ff;
  color: #227cf6;
}

.follow-detail {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.follow-time {
  color: #1d2733;
  font-size: 28rpx;
  font-weight: 900;
}

.plan-meta-row {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: #f6f9fd;
  color: #566476;
  font-size: 24rpx;
  font-weight: 800;
}

.plan-status {
  background: #eef4ff;
  color: #227cf6;
}

.device-state {
  background: #e2f7ec;
  color: #14875a;
}

.placeholder-card {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 20rpx;
}

.placeholder-title {
  color: #1d2733;
  font-size: 38rpx;
  font-weight: 900;
}

.placeholder-desc {
  color: #667487;
  font-size: 27rpx;
  line-height: 1.5;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.52);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-box {
  width: 100%;
  padding: 40rpx 36rpx calc(env(safe-area-inset-bottom) + 40rpx);
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.advice-drawer-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.drawer-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #2478ff;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.drawer-doctor {
  color: #2478ff;
  font-size: 26rpx;
  font-weight: 800;
}

.drawer-time {
  color: #a1adba;
  font-size: 22rpx;
}

.advice-drawer-title {
  display: block;
  margin-bottom: 16rpx;
  color: #1d2733;
  font-size: 36rpx;
  font-weight: 900;
}

.advice-drawer-content {
  display: block;
  margin-bottom: 28rpx;
  color: #3a4a5a;
  font-size: 28rpx;
  line-height: 1.7;
}

.modal-actions {
  display: flex;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #d0daea;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4e6074;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
}
