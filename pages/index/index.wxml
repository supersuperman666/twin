<view class="page">
  <view wx:if="{{userStage === 'managed'}}">
    <view class="status-card">
      <view class="status-main">
        <view class="status-copy">
          <text class="status-kicker">今日状态</text>
          <text class="status-title">{{currentPatient.name}}，{{todayStatus.label}}</text>
          <text class="status-desc">{{todayStatus.desc}}</text>
        </view>
        <view class="score-ring">
          <text class="score-value">{{todayStatus.score}}</text>
          <text class="score-label">健康分</text>
        </view>
      </view>
      <view class="status-foot">
        <text>较昨日 {{todayStatus.change}}</text>
        <text>{{currentPatient.patientDesc}}</text>
      </view>
      <view class="indicator-grid">
        <view wx:for="{{coreIndicators}}" wx:key="label" class="indicator-card {{item.tone}}" data-path="{{item.path}}" bindtap="goPath">
          <view class="indicator-top">
            <text class="indicator-label">{{item.label}}</text>
            <text class="indicator-status">{{item.status}}</text>
          </view>
          <view class="indicator-value-row">
            <text class="indicator-value">{{item.value}}</text>
            <text class="indicator-unit">{{item.unit}}</text>
          </view>
          <text class="indicator-meta">{{item.meta}}</text>
        </view>
      </view>
    </view>

    <view class="section-head compact">
      <text>快捷记录</text>
    </view>
    <view class="quick-grid">
      <view wx:for="{{quickRecords}}" wx:key="label" class="quick" data-path="{{item.path}}" bindtap="goPath">
        <view class="quick-icon">
          <view wx:if="{{item.type === 'glucose'}}" class="css-icon glucose-icon"></view>
          <view wx:elif="{{item.type === 'pressure'}}" class="css-icon pressure-mini"></view>
          <view wx:elif="{{item.type === 'medicine'}}" class="css-icon pill-icon"><view></view></view>
          <view wx:elif="{{item.type === 'symptom'}}" class="css-icon symptom-icon"></view>
          <view wx:else class="css-icon more-icon"></view>
        </view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <view wx:if="{{riskAlert}}" class="module-card risk-card">
      <view class="module-title tight">
        <view>
          <text class="module-kicker">风险预警</text>
          <text class="module-heading">{{riskAlert.title}}</text>
        </view>
        <text class="risk-tag">{{riskAlert.level}}</text>
      </view>
      <text class="module-desc">{{riskAlert.desc}}</text>
      <view class="card-actions">
        <button class="primary-action" data-path="{{riskAlert.path}}" bindtap="goPath">{{riskAlert.action}}</button>
        <button class="ghost-action" data-path="/pages/alerts/index" bindtap="goPath">查看全部风险</button>
      </view>
    </view>

    <view class="module-card">
      <view class="module-title">
        <view>
          <text class="module-kicker">今日待办</text>
          <text class="module-heading">{{taskSummary.done}}/{{taskSummary.total}} 已完成</text>
        </view>
        <button class="link-btn" data-path="/pages/me/tasks/index" bindtap="goPath">查看全部</button>
      </view>
      <view class="todo-list">
        <view wx:for="{{todayTasks}}" wx:key="id" class="todo-row {{item.status}}">
          <view class="todo-dot">{{item.status === 'done' ? '✓' : ''}}</view>
          <view class="todo-info">
            <text class="todo-title">{{item.title}}</text>
            <text class="todo-meta">{{item.time}}｜{{item.source}}</text>
          </view>
          <button wx:if="{{item.status !== 'done'}}" class="todo-action" data-path="{{item.path}}" bindtap="goPath">{{item.action}}</button>
          <text wx:else class="done-label">已完成</text>
        </view>
      </view>
    </view>

    <view wx:if="{{doctorArrangement}}" class="module-card doctor-card">
      <view class="module-title tight">
        <view>
          <text class="module-kicker">医生新安排</text>
          <text class="module-heading">{{doctorArrangement.title}}</text>
        </view>
        <text class="doctor-name">{{doctorArrangement.doctorName}}</text>
      </view>
      <text class="module-desc two-line">{{doctorArrangement.desc}}</text>
      <view class="card-actions">
        <button class="primary-action" bindtap="onAdviceTap">查看</button>
      </view>
    </view>

    <view wx:if="{{nearestFollowup}}" class="module-card follow-card">
      <view class="module-title tight">
        <view>
          <text class="module-kicker">下次随访</text>
          <text class="module-heading">{{nearestFollowup.title}}</text>
        </view>
        <text class="method-tag">{{nearestFollowup.method}}</text>
      </view>
      <view class="follow-detail">
        <text class="follow-time">{{nearestFollowup.dueAt}}</text>
        <text class="module-desc">{{nearestFollowup.patientInstruction}}</text>
      </view>
      <view class="card-actions">
        <button class="ghost-action" data-path="/pages/followup/records/index" bindtap="goPath">查看准备事项</button>
      </view>
    </view>

    <view wx:if="{{deviceStatus}}" class="module-card device-lite">
      <view class="module-title tight">
        <view>
          <text class="module-kicker">我的设备</text>
          <text class="module-heading">已绑定 {{deviceStatus.count}} 台</text>
        </view>
        <text class="device-state {{deviceStatus.abnormal ? 'warn' : ''}}">{{deviceStatus.abnormal ? '需处理' : '正常'}}</text>
      </view>
      <text class="module-desc">{{deviceStatus.abnormal ? deviceStatus.desc : '设备同步正常'}}｜最近同步：{{deviceStatus.latestSync}}</text>
      <view class="card-actions">
        <button class="ghost-action" data-path="/pages/device/index/index" bindtap="goPath">查看设备</button>
      </view>
    </view>
  </view>

  <view wx:elif="{{userStage === 'new' || userStage === 'screening_draft'}}" class="new-home">
    <view class="screening-card">
      <view class="screening-main">
        <view>
          <text class="screening-status">{{newUserGuide.screening.status}}</text>
          <text class="screening-title">{{newUserGuide.screening.title}}</text>
          <text class="screening-desc">{{newUserGuide.screening.desc}}</text>
        </view>
        <view class="screening-badge">评</view>
      </view>
      <view class="screening-note">{{newUserGuide.screening.note}}</view>
      <button class="screening-btn" bindtap="handlePrimaryAction">{{newUserGuide.screening.action}}</button>
    </view>

    <view class="new-module">
      <view class="new-module-copy">
        <text class="new-module-title">{{newUserGuide.doctor.title}}</text>
        <text class="new-module-desc">{{newUserGuide.doctor.desc}}</text>
        <text class="new-module-note">{{newUserGuide.doctor.note}}</text>
      </view>
      <button class="new-module-action" bindtap="onDoctorBindTap">{{newUserGuide.doctor.action}}</button>
    </view>

    <view class="new-module profile-guide" data-path="/pages/profile/index" bindtap="goPath">
      <view class="new-module-copy">
        <text class="new-module-title">完善健康档案</text>
        <text class="new-module-desc">补充基础信息、既往病史、当前用药和设备情况。</text>
        <text class="new-module-note">待补充：{{newUserGuide.profile.items}}</text>
      </view>
      <view class="profile-progress">
        <text>{{newUserGuide.profile.percent}}%</text>
        <view><view style="width: {{newUserGuide.profile.percent}}%;"></view></view>
      </view>
    </view>

    <view class="section-head compact">
      <text>有近期数据？先记一笔</text>
    </view>
    <view class="quick-grid">
      <view wx:for="{{newUserQuickRecords}}" wx:key="label" class="quick" data-path="{{item.path}}" bindtap="goPath">
        <view class="quick-icon">
          <view wx:if="{{item.type === 'glucose'}}" class="css-icon glucose-icon"></view>
          <view wx:elif="{{item.type === 'pressure'}}" class="css-icon pressure-mini"></view>
          <view wx:elif="{{item.type === 'oxygen'}}" class="css-icon oxygen-icon"></view>
          <view wx:elif="{{item.type === 'medicine'}}" class="css-icon pill-icon"><view></view></view>
          <view wx:else class="css-icon more-icon"></view>
        </view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <view class="new-module device-guide">
      <view class="new-module-copy">
        <text class="new-module-title">已有设备？先完成绑定</text>
        <text class="new-module-desc">{{newUserGuide.device.title}}</text>
        <text class="new-module-note">设备数据可作为筛查和后续管理参考。</text>
      </view>
      <button class="new-module-action" data-path="/pages/device/index/index" bindtap="goPath">{{newUserGuide.device.action}}</button>
    </view>

    <view class="bottom-note">筛查结果仅用于健康风险提示，正式诊断和治疗建议以医生判断为准。</view>
  </view>

  <view wx:elif="{{userStage === 'assessed'}}" class="assessed-home">
    <view class="result-card">
      <text class="screening-status">{{assessedGuide.result.status}}</text>
      <text class="screening-title">{{assessedGuide.result.title}}</text>
      <text class="screening-desc">{{assessedGuide.result.desc}}</text>
      <view class="risk-grid">
        <view wx:for="{{assessedGuide.result.risks}}" wx:key="label" class="risk-chip">
          <text>{{item.label}}</text>
          <text>{{item.value}}</text>
        </view>
      </view>
      <view class="result-actions">
        <button class="screening-btn" bindtap="handlePrimaryAction">查看筛查结果</button>
        <button class="outline-btn" bindtap="onDoctorBindTap">绑定医生</button>
      </view>
    </view>

    <view class="new-module">
      <view class="new-module-copy">
        <text class="new-module-title">{{assessedGuide.doctor.title}}</text>
        <text class="new-module-desc">{{assessedGuide.doctor.desc}}</text>
      </view>
      <button class="new-module-action" bindtap="onDoctorBindTap">{{assessedGuide.doctor.action}}</button>
    </view>

    <view class="new-module profile-guide" data-path="/pages/profile/index" bindtap="goPath">
      <view class="new-module-copy">
        <text class="new-module-title">完善健康档案</text>
        <text class="new-module-desc">完善基础信息、既往病史、当前用药和设备情况，帮助医生更准确判断风险。</text>
        <text class="new-module-note">待补充：{{assessedGuide.profile.items}}</text>
      </view>
      <view class="profile-progress">
        <text>{{assessedGuide.profile.percent}}%</text>
        <view><view style="width: {{assessedGuide.profile.percent}}%;"></view></view>
      </view>
    </view>

    <view class="section-head compact">
      <text>补充近期记录</text>
    </view>
    <view class="quick-grid">
      <view wx:for="{{newUserQuickRecords}}" wx:key="label" class="quick" data-path="{{item.path}}" bindtap="goPath">
        <view class="quick-icon">
          <view wx:if="{{item.type === 'glucose'}}" class="css-icon glucose-icon"></view>
          <view wx:elif="{{item.type === 'pressure'}}" class="css-icon pressure-mini"></view>
          <view wx:elif="{{item.type === 'oxygen'}}" class="css-icon oxygen-icon"></view>
          <view wx:elif="{{item.type === 'medicine'}}" class="css-icon pill-icon"><view></view></view>
          <view wx:else class="css-icon more-icon"></view>
        </view>
        <text>{{item.label}}</text>
      </view>
    </view>

    <view class="new-module device-guide">
      <view class="new-module-copy">
        <text class="new-module-title">我的设备</text>
        <text class="new-module-desc">{{assessedGuide.device.title}}</text>
        <text class="new-module-note">设备数据可作为医生后续判断风险的参考。</text>
      </view>
      <button class="new-module-action" data-path="/pages/device/index/index" bindtap="goPath">{{assessedGuide.device.action}}</button>
    </view>

    <view class="bottom-note">筛查结果仅为健康风险提示，不作为诊断结论；是否进入正式管理需结合医生判断。</view>
  </view>

  <view wx:else class="placeholder-card">
    <text class="placeholder-title">先完成健康筛查</text>
    <text class="placeholder-desc">约 3 分钟完成，帮助医生了解你的慢病风险。</text>
    <button class="primary-action" bindtap="handlePrimaryAction">开始健康筛查</button>
  </view>

  <view wx:if="{{showAdviceDrawer}}" class="modal-mask" bindtap="onAdviceClose">
    <view class="modal-box advice-drawer-box" catchtap="noop">
      <view class="advice-drawer-header">
        <view class="drawer-avatar">医</view>
        <text class="drawer-doctor">{{currentAdvice.doctorName}}</text>
        <text class="drawer-time">{{currentAdvice.sentAt}}</text>
      </view>
      <text class="advice-drawer-title">{{currentAdvice.title}}</text>
      <text class="advice-drawer-content">{{currentAdvice.content}}</text>
      <view class="modal-actions">
        <button class="action-btn ghost sm" bindtap="onAdviceClose">关闭</button>
      </view>
    </view>
  </view>
</view>
