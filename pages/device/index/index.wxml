<view class="page">
  <view class="nav-row">
    <view class="back" bindtap="goBack">‹</view>
    <text class="nav-title">智能硬件</text>
    <view class="nav-space"></view>
  </view>

  <view class="hardware-shell">
    <view class="category-rail">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{activeKey == item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="switchCategory"
      >
        <view class="category-icon category-icon-{{item.key}}">{{item.icon}}</view>
        <text>{{item.name}}</text>
      </view>
    </view>

    <scroll-view class="device-panel" scroll-y>
      <view class="panel-title">{{activeName}}</view>
      <view wx:for="{{currentDevices}}" wx:key="id" class="device-card">
        <view class="device-image">
          <text>{{item.icon}}</text>
        </view>
        <view class="device-info">
          <text class="device-name">{{item.name}}</text>
        </view>
        <button class="bind-btn {{item.bound ? 'danger' : ''}}" data-id="{{item.id}}" bindtap="handleDeviceAction">{{item.actionText}}</button>
      </view>
    </scroll-view>
  </view>
</view>
