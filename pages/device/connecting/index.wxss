.connecting-page {
  min-height: 100vh;
  padding: 150rpx 54rpx 64rpx;
  box-sizing: border-box;
  background: #ffffff;
  color: #20242a;
  text-align: center;
}

.scan-ring {
  width: 212rpx;
  height: 212rpx;
  margin: 0 auto 46rpx;
  border-radius: 50%;
  border: 8rpx solid #d7eaff;
  background: #f1f8ff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 0 24rpx rgba(35, 123, 232, .08);
}

.scan-core {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: #237be8;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.device {
  display: block;
  margin-top: 18rpx;
  color: #237be8;
  font-size: 28rpx;
  font-weight: 800;
}

.desc {
  display: block;
  margin-top: 30rpx;
  color: #8a96a3;
  font-size: 27rpx;
  line-height: 1.7;
}

.ghost-btn {
  width: 320rpx;
  height: 78rpx;
  margin-top: 72rpx;
  border-radius: 40rpx;
  background: #f1f6ff;
  color: #237be8;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 78rpx;
}

.ghost-btn::after {
  border: 0;
}
