.page {
  min-height: 100vh;
  background: #EEF2F6;
  padding: 24rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  color: #16202D;
  font-size: 38rpx;
  font-weight: 900;
}

.page-desc {
  display: block;
  margin-top: 10rpx;
  color: #6D7A89;
  font-size: 25rpx;
  line-height: 1.6;
}

.timeline-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.timeline-side {
  width: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-top: 22rpx;
  background: #237BE8;
  box-shadow: 0 0 0 8rpx rgba(35, 123, 232, 0.12);
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  margin-top: 12rpx;
  background: #D9E1EA;
}

.timeline-main {
  flex: 1;
}

.plan-card,
.empty-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 2rpx solid #E7ECF2;
  padding: 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(39, 63, 94, 0.05);
}

.empty-text {
  color: #6D7A89;
  font-size: 26rpx;
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.time-text {
  display: block;
  color: #7D8896;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.title-text {
  display: block;
  color: #16202D;
  font-size: 30rpx;
  font-weight: 800;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.meta-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #EEF5FF;
  color: #237BE8;
  font-size: 22rpx;
  font-weight: 700;
}

.summary-text {
  display: block;
  margin-top: 12rpx;
  color: #425063;
  font-size: 25rpx;
  line-height: 1.6;
}

.badge {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.badge.done {
  background: #E9F8F2;
  color: #209C73;
}

.badge.replaced {
  background: #EDF2F8;
  color: #627084;
}

.expand-body {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #EEF2F6;
}

.detail-group + .detail-group {
  margin-top: 18rpx;
}

.detail-title {
  display: block;
  color: #16202D;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.detail-row {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.bullet {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #237BE8;
  margin-top: 14rpx;
}

.detail-row text {
  flex: 1;
  color: #425063;
  font-size: 25rpx;
  line-height: 1.6;
}
