page {
  background: #f4f7fb;
}

.page {
  min-height: 100vh;
  color: #17212b;
  background: #f4f7fb;
}

button {
  margin: 0;
  padding: 0;
}

button::after {
  border: 0;
}

.plan-page {
  padding: 20rpx 28rpx 132rpx;
  box-sizing: border-box;
}

.plan-page.has-fixed-actions {
  padding-bottom: 228rpx;
}

.hero-card,
.section-card,
.history-entry,
.empty-state,
.modal-box {
  border: 1rpx solid #e1e9f2;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(40, 82, 126, 0.06);
  box-sizing: border-box;
}

.pending-banner {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #ffdca6;
  border-radius: 18rpx;
  background: #fff8ed;
}

.pending-dot {
  width: 18rpx;
  height: 18rpx;
  flex: 0 0 18rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #f59e0b;
  box-shadow: 0 0 0 8rpx rgba(245, 158, 11, 0.14);
}

.pending-title {
  display: block;
  color: #8a4b08;
  font-size: 28rpx;
  font-weight: 900;
}

.pending-desc {
  display: block;
  margin-top: 6rpx;
  color: #a9660a;
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-card {
  padding: 30rpx 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #237be8 0%, #17a98a 100%);
  border: 0;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.hero-kicker {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
  font-weight: 900;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.hero-stage {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.4;
}

.status-badge {
  flex: 0 0 auto;
  padding: 9rpx 17rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.status-badge.pending {
  background: #fff1d8;
  color: #b85c00;
}

.status-badge.active {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.hero-meta {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.hero-meta view,
.disease-row {
  padding: 16rpx;
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.14);
}

.hero-meta text:first-child,
.disease-row text:first-child {
  display: block;
  color: rgba(255, 255, 255, 0.72);
  font-size: 21rpx;
  font-weight: 800;
}

.hero-meta text:last-child,
.disease-row text:last-child {
  display: block;
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.3;
}

.disease-row {
  margin-top: 12rpx;
}

.section-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.section-title {
  display: block;
  color: #1d2733;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.3;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.goal-list,
.plain-list,
.target-list,
.prepare-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goal-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f7faff;
}

.goal-index {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
  border-radius: 50%;
  background: #237be8;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.goal-row text,
.plain-row text,
.prepare-row text {
  min-width: 0;
  flex: 1;
  color: #3a4858;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 1.5;
}

.plain-row,
.prepare-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.plain-dot {
  width: 12rpx;
  height: 12rpx;
  flex: 0 0 12rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #237be8;
}

.plain-row.med .plain-dot {
  background: #7c6df0;
}

.plain-row.device .plain-dot {
  background: #17a98a;
}

.target-list {
  gap: 14rpx;
}

.target-card {
  padding: 20rpx;
  border: 1rpx solid #dce8f7;
  border-radius: 16rpx;
  background: #f8fbff;
}

.target-title {
  display: block;
  color: #237be8;
  font-size: 24rpx;
  font-weight: 900;
}

.target-desc {
  display: block;
  margin-top: 8rpx;
  color: #1d2733;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.section-note {
  display: block;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: #f6f8fb;
  color: #718092;
  font-size: 23rpx;
  line-height: 1.45;
}

.link-btn {
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #e8f2ff;
  color: #237be8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.follow-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f7faff;
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.date-box {
  min-width: 156rpx;
  flex: 0 0 156rpx;
  padding: 16rpx 12rpx;
  border-radius: 15rpx;
  background: #237be8;
  color: #ffffff;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.follow-copy {
  min-width: 0;
  flex: 1;
}

.follow-title {
  display: block;
  color: #1d2733;
  font-size: 28rpx;
  font-weight: 900;
}

.follow-desc {
  display: block;
  margin-top: 8rpx;
  color: #6f7d8c;
  font-size: 24rpx;
  line-height: 1.42;
}

.prepare-title {
  color: #1d2733;
  font-size: 26rpx;
  font-weight: 900;
}

.change-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.change-date {
  display: block;
  color: #237be8;
  font-size: 24rpx;
  font-weight: 900;
}

.change-title {
  display: block;
  margin: 8rpx 0 16rpx;
  color: #1d2733;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.4;
}

.notice-card {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #ffd4da;
  border-radius: 18rpx;
  background: #fff8f9;
  color: #b93441;
  font-size: 24rpx;
  font-weight: 750;
  line-height: 1.52;
}

.history-entry {
  margin-top: 22rpx;
  padding: 24rpx 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.history-title {
  display: block;
  color: #1d2733;
  font-size: 29rpx;
  font-weight: 900;
}

.history-desc {
  display: block;
  margin-top: 8rpx;
  color: #7b8796;
  font-size: 24rpx;
}

.history-arrow {
  color: #a1adba;
  font-size: 46rpx;
  line-height: 1;
}

.confirm-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 22rpx 28rpx calc(env(safe-area-inset-bottom) + 22rpx);
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  gap: 16rpx;
  border-top: 1rpx solid #dce6f1;
  background: rgba(244, 247, 251, 0.96);
  backdrop-filter: blur(10px);
}

.primary-btn,
.ghost-btn {
  height: 74rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1;
}

.primary-btn {
  background: #237be8;
  color: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(35, 123, 232, 0.22);
}

.ghost-btn {
  border: 1rpx solid #d2deeb;
  background: #ffffff;
  color: #4e6074;
}

.empty-state {
  margin: 120rpx 36rpx 0;
  padding: 56rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-symbol {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e8f2ff;
  color: #237be8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  font-weight: 900;
}

.empty-title {
  margin-top: 28rpx;
  color: #1d2733;
  font-size: 33rpx;
  font-weight: 900;
  text-align: center;
}

.empty-desc {
  margin-top: 14rpx;
  color: #6f7d8c;
  font-size: 25rpx;
  line-height: 1.5;
  text-align: center;
}

.empty-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  width: 100%;
  margin-top: 34rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(15, 23, 42, 0.52);
  display: flex;
  align-items: flex-end;
}

.modal-box {
  width: 100%;
  padding: 38rpx 34rpx calc(env(safe-area-inset-bottom) + 34rpx);
  border-radius: 30rpx 30rpx 0 0;
  border: 0;
}

.modal-title {
  display: block;
  color: #1d2733;
  font-size: 34rpx;
  font-weight: 900;
}

.modal-input {
  width: 100%;
  min-height: 190rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f5f7fb;
  color: #1d2733;
  font-size: 27rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}
