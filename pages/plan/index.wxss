/* ─── 页面基础 ─── */
page { background: #EEF2F6; }

.page {
  min-height: 100vh;
  background: #EEF2F6;
  color: #16202D;
}

/* ─── 空状态 ─── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 60rpx;
}

.empty-icon-box {
  margin-bottom: 48rpx;
}

.empty-icon-inner {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E9F3FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon-text {
  font-size: 56rpx;
  font-weight: 800;
  color: #1F82FF;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 16rpx;
  text-align: center;
}

.empty-desc {
  font-size: 26rpx;
  color: #5D6A7A;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 48rpx;
}

/* ─── 通用按钮 ─── */
.btn-primary {
  height: 88rpx;
  padding: 0 48rpx;
  border-radius: 24rpx;
  background: #1F82FF;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(31, 130, 255, 0.2);
}

.btn-primary::after { border: 0; }

.btn-ghost {
  height: 88rpx;
  padding: 0 40rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E7ECF2;
  color: #425063;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.btn-ghost::after { border: 0; }

/* ─── 通用卡片 ─── */
.card {
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 2rpx solid #E7ECF2;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 0 rgba(20, 36, 54, 0.02);
}

/* ─── 徽章 ─── */
.badge {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.badge-pending {
  background: #FFF4DB;
  color: #F59E0B;
}

.badge-active {
  background: #E9F3FF;
  color: #1F82FF;
}

.badge-unread {
  background: #1F82FF;
  color: #FFFFFF;
}

.badge-read {
  background: #EDF2F8;
  color: #627084;
}

.badge-temp {
  background: #FFF4DB;
  color: #F59E0B;
}

.badge-pending {
  background: #FFF4DB;
  color: #F59E0B;
}

.badge-partial {
  background: #E9F3FF;
  color: #1F82FF;
}

.badge-ready {
  background: #E8F8F1;
  color: #10B981;
}

/* ─── 待确认态 ─── */
.confirm-page {
  padding: 24rpx 32rpx 240rpx;
}

.notify-banner {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: #FFF4DB;
  border: 2rpx solid #F59E0B;
}

.banner-dot {
  width: 16rpx;
  height: 16rpx;
  flex: 0 0 16rpx;
  border-radius: 50%;
  background: #F59E0B;
  box-shadow: 0 0 0 6rpx rgba(245, 158, 11, 0.2);
  margin-top: 6rpx;
}

.banner-body { flex: 1; }

.banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #92530A;
  margin-bottom: 4rpx;
}

.banner-sub {
  display: block;
  font-size: 24rpx;
  color: #B8700F;
}

/* 方案头卡 */
.plan-header-card {
  margin-bottom: 24rpx;
}

.plan-header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.plan-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #16202D;
  line-height: 1.3;
}

.plan-stage {
  display: block;
  font-size: 26rpx;
  color: #5D6A7A;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.plan-meta {
  font-size: 24rpx;
  color: #8D99A8;
  line-height: 1.5;
}

.plan-meta-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 4rpx;
}

.plan-objective-box {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #E9F3FF;
  margin-top: 20rpx;
}

.plan-objective-label {
  display: block;
  font-size: 22rpx;
  font-weight: 800;
  color: #1F82FF;
  margin-bottom: 8rpx;
}

.plan-objective-text {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #16202D;
  line-height: 1.5;
}

/* 方案明细（待确认态） */
.section-block {
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 2rpx solid #E7ECF2;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 0 rgba(20, 36, 54, 0.02);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 20rpx;
}

.section-head-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-head-inline .section-title {
  margin-bottom: 0;
}

.ghost-link {
  color: #237BE8;
  font-size: 24rpx;
  font-weight: 700;
}

.section-link-row {
  margin-top: 8rpx;
  display: flex;
  justify-content: flex-end;
}

.followup-current-card {
  margin-bottom: 0;
}

.bottom-links-block {
  display: flex;
  justify-content: center;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.item-dot {
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 10rpx;
  border-radius: 50%;
  background: #1F82FF;
  margin-top: 14rpx;
}

.lifestyle-dot { background: #F59E0B; }
.med-dot { background: #7C6DF0; }
.device-dot { background: #10B981; }
.followup-dot { background: #1F82FF; }

.item-row text {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  color: #3A4A5A;
  line-height: 1.55;
}

/* 异常提示 */
.abnormal-tips {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #FEECEC;
  border: 2rpx solid #EF4444;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #EF4444;
  font-weight: 700;
  line-height: 1.5;
}

.tips-icon {
  width: 36rpx;
  height: 36rpx;
  flex: 0 0 36rpx;
  border-radius: 50%;
  border: 3rpx solid #EF4444;
  color: #EF4444;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 吸底确认按钮 */
.confirm-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  display: flex;
  gap: 20rpx;
  background: rgba(238, 242, 246, 0.96);
  backdrop-filter: blur(10px);
  border-top: 2rpx solid #E7ECF2;
  z-index: 50;
}

.confirm-actions .btn-primary,
.confirm-actions .btn-ghost { flex: 1; }

/* ─── 执行态连续流 ─── */
.active-page {
  padding: 24rpx 32rpx 120rpx;
}

/* 最近安排 */
.advice-card {
  margin-bottom: 16rpx;
}

.advice-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.advice-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #1F82FF;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.advice-from {
  font-size: 24rpx;
  font-weight: 800;
  color: #1F82FF;
}

.advice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 8rpx;
}

.advice-summary {
  display: block;
  font-size: 24rpx;
  color: #5D6A7A;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  margin-bottom: 8rpx;
}

.advice-time {
  display: block;
  font-size: 22rpx;
  color: #8D99A8;
}

/* 卡片内操作按钮 */
.card-action-btn {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: #E9F3FF;
  color: #1F82FF;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
}

/* 复测卡片 */
.recheck-card {
  margin-bottom: 16rpx;
}

.recheck-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.recheck-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #1F82FF;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recheck-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #16202D;
}

.recheck-summary {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #1F82FF;
  margin-bottom: 8rpx;
}

.recheck-instruction {
  display: block;
  font-size: 24rpx;
  color: #5D6A7A;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.recheck-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.recheck-status {
  font-size: 24rpx;
  font-weight: 800;
  color: #10B981;
}

.recheck-remaining {
  font-size: 24rpx;
  font-weight: 700;
  color: #F59E0B;
}

/* 随访卡片 */
.followup-card {
  margin-bottom: 16rpx;
}

.followup-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.followup-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #10B981;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.followup-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #16202D;
}

.followup-time {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 8rpx;
}

.followup-method-tag {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #E9F3FF;
  color: #1F82FF;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.followup-instruction {
  display: block;
  font-size: 24rpx;
  color: #5D6A7A;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

/* 空状态区块 */
.empty-section {
  padding: 32rpx;
  text-align: center;
}

.empty-section-text {
  font-size: 26rpx;
  color: #8D99A8;
}

/* 今日任务轻入口 */
.today-task-card {
  display: flex;
  flex-direction: column;
}

.today-task-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.today-task-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #16202D;
}

.today-task-desc {
  display: block;
  font-size: 24rpx;
  color: #5D6A7A;
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.today-task-done {
  color: #10B981;
}

/* 方案明细（执行态下沉） */
.detail-section {
  margin-bottom: 24rpx;
}

.detail-group {
  margin-bottom: 24rpx;
}

.detail-group:last-child {
  margin-bottom: 0;
}

.detail-group-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 16rpx;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.detail-dot {
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 10rpx;
  border-radius: 50%;
  background: #1F82FF;
  margin-top: 14rpx;
}

.metric-dot { background: #1F82FF; }
.warn-dot { background: #EF4444; }

.detail-item text {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  color: #3A4A5A;
  line-height: 1.55;
}

.abnormal-item text {
  color: #EF4444;
}

/* ─── 疑问弹窗 ─── */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.52);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-box {
  width: 100%;
  padding: 40rpx 36rpx calc(env(safe-area-inset-bottom) + 40rpx);
  border-radius: 40rpx 40rpx 0 0;
  background: #FFFFFF;
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 8rpx;
}

.modal-input {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F6F8FB;
  border: 2rpx solid #E7ECF2;
  font-size: 28rpx;
  color: #16202D;
  line-height: 1.6;
  margin-bottom: 28rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 18rpx;
}

.modal-actions .btn-primary,
.modal-actions .btn-ghost { flex: 1; }

/* ─── 建议抽屉 ─── */
.advice-drawer-box {
  padding-top: 36rpx;
}

.advice-drawer-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.drawer-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #1F82FF;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.drawer-doctor {
  font-size: 26rpx;
  font-weight: 800;
  color: #1F82FF;
}

.drawer-time {
  font-size: 22rpx;
  color: #8D99A8;
}

.drawer-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 16rpx;
}

.drawer-content {
  display: block;
  font-size: 28rpx;
  color: #3A4A5A;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.drawer-status {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
}

.drawer-status.is-unread {
  background: #1F82FF;
  color: #FFFFFF;
}

.drawer-status.is-read {
  background: #EDF2F8;
  color: #627084;
}
