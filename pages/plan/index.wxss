.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 156rpx;
  background: #f6f7f9;
  color: #17212b;
}

.summary-card {
  padding: 32rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #237be8 0%, #20b6d3 58%, #15b981 100%);
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  gap: 28rpx;
  box-shadow: 0 18rpx 38rpx rgba(35, 123, 232, 0.18);
}

.summary-title {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
}

.summary-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.45;
}

.score-ring {
  width: 124rpx;
  height: 124rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  flex: 0 0 124rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-ring text:first-child {
  font-size: 36rpx;
  font-weight: 900;
}

.score-ring text:last-child {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.82);
}

.section-head {
  margin: 34rpx 0 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-head text:first-child {
  font-size: 31rpx;
  font-weight: 900;
}

.section-extra {
  color: #237be8;
  font-size: 24rpx;
  font-weight: 800;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-card {
  min-height: 112rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 50rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
}

.task-check {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #edf3fb;
  color: #667085;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 900;
}

.task-card.done .task-check {
  background: #dcfae6;
  color: #17a466;
}

.task-title {
  display: block;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 800;
}

.task-desc {
  display: block;
  margin-top: 8rpx;
  color: #8a96a3;
  font-size: 23rpx;
}

.task-action {
  color: #237be8;
  font-size: 24rpx;
  font-weight: 800;
}

.focus-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.focus-card,
.advice-card {
  border-radius: 18rpx;
  background: #ffffff;
}

.focus-card {
  min-height: 148rpx;
  padding: 22rpx 18rpx;
}

.focus-label {
  display: block;
  color: #8a96a3;
  font-size: 22rpx;
  font-weight: 700;
}

.focus-value {
  display: block;
  margin-top: 12rpx;
  color: #1f2937;
  font-size: 31rpx;
  font-weight: 900;
}

.focus-desc {
  display: block;
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 20rpx;
  line-height: 1.3;
}

.advice-card {
  padding: 28rpx;
}

.advice-title {
  display: block;
  color: #1f2937;
  font-size: 29rpx;
  font-weight: 900;
}

.advice-desc {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.5;
}
