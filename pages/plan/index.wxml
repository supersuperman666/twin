<view class="page">
  <view wx:if="{{pageState === 'empty'}}" class="empty-state">
    <view class="empty-symbol">方</view>
    <text class="empty-title">当前还没有生效中的管理方案</text>
    <text class="empty-desc">医生确认并下发后，你可以在这里查看当前方案和长期管理要求。</text>
    <view class="empty-actions">
      <button class="primary-btn" bindtap="goScreening">去完成健康筛查</button>
      <button class="ghost-btn" bindtap="goHome">返回首页</button>
    </view>
  </view>

  <view wx:elif="{{pageState === 'pending_confirm' || pageState === 'active'}}" class="plan-page {{pageState === 'pending_confirm' ? 'has-fixed-actions' : ''}}">
    <view wx:if="{{pageState === 'pending_confirm'}}" class="pending-banner">
      <view class="pending-dot"></view>
      <view>
        <text class="pending-title">医生已下发新的管理方案</text>
        <text class="pending-desc">请阅读长期管理要求，确认知晓后开始执行。</text>
      </view>
    </view>

    <view class="hero-card">
      <view class="hero-top">
        <view class="hero-copy">
          <text class="hero-kicker">当前方案</text>
          <text class="hero-title">{{planView.header.title}}</text>
          <text class="hero-stage">{{planView.header.stage}}</text>
        </view>
        <text class="status-badge {{pageState === 'pending_confirm' ? 'pending' : 'active'}}">{{planView.header.statusText}}</text>
      </view>
      <view class="hero-meta">
        <view>
          <text>主责医生</text>
          <text>{{planView.header.doctor}}</text>
        </view>
        <view>
          <text>生效时间</text>
          <text>{{planView.header.startDate || '确认后生效'}}</text>
        </view>
        <view>
          <text>方案周期</text>
          <text>{{planView.header.period}}</text>
        </view>
      </view>
      <view class="disease-row">
        <text>适用疾病</text>
        <text>{{planView.header.diseases}}</text>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">本阶段目标</text>
      <view class="goal-list">
        <view wx:for="{{planView.stageGoals}}" wx:key="index" class="goal-row">
          <view class="goal-index">{{index + 1}}</view>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">医生确认的管理要求</text>
      <view class="plain-list">
        <view wx:for="{{planView.managementRequirements}}" wx:key="index" class="plain-row">
          <view class="plain-dot"></view>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">指标目标</text>
      <view class="target-list">
        <view wx:for="{{planView.metricTargets}}" wx:key="id" class="target-card" data-path="{{item.path}}" bindtap="goPath">
          <text class="target-title">{{item.title}}</text>
          <text class="target-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">用药 / 治疗要求</text>
      <view class="plain-list">
        <view wx:for="{{planView.medicationRequirements}}" wx:key="index" class="plain-row med">
          <view class="plain-dot"></view>
          <text>{{item}}</text>
        </view>
      </view>
      <text class="section-note">药品、剂量和频次由医生维护，患者只记录实际执行情况。</text>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">设备要求</text>
        <button class="link-btn" data-path="/pages/device/index/index" bindtap="goPath">去设备页</button>
      </view>
      <view class="plain-list">
        <view wx:for="{{planView.deviceRequirements}}" wx:key="index" class="plain-row device">
          <view class="plain-dot"></view>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-head">
        <text class="section-title">随访安排</text>
        <button class="link-btn" data-path="/pages/followup/records/index" bindtap="goPath">查看全部</button>
      </view>
      <view class="follow-card">
        <view class="date-box">
          <text>{{planView.followup.date}}</text>
        </view>
        <view class="follow-copy">
          <text class="follow-title">{{planView.followup.label}}</text>
          <text class="follow-desc">{{planView.followup.frequency}}</text>
        </view>
      </view>
      <view class="prepare-list">
        <text class="prepare-title">随访前请准备</text>
        <view wx:for="{{planView.followup.prepare}}" wx:key="index" class="prepare-row">
          <view class="plain-dot"></view>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{pageState === 'active'}}" class="section-card">
      <text class="section-title">最近方案调整</text>
      <view class="change-card">
        <text class="change-date">{{planView.recentChange.date}}</text>
        <text class="change-title">{{planView.recentChange.doctor}}更新了本阶段管理要求</text>
        <view wx:for="{{planView.recentChange.items}}" wx:key="index" class="plain-row">
          <view class="plain-dot"></view>
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{planView.guidanceNote}}" class="notice-card">
      <text>{{planView.guidanceNote}}</text>
    </view>

    <view class="history-entry" bindtap="onGoHistoryPlans">
      <view>
        <text class="history-title">历史方案</text>
        <text class="history-desc">查看已结束或已替换的方案</text>
      </view>
      <text class="history-arrow">›</text>
    </view>

    <view wx:if="{{pageState === 'pending_confirm'}}" class="confirm-actions">
      <button class="ghost-btn" bindtap="onQuestionTap">我有疑问</button>
      <button class="primary-btn" bindtap="onConfirmPlan">我已知晓，开始执行</button>
    </view>
  </view>

  <view wx:if="{{showQuestionModal}}" class="modal-mask" bindtap="onCloseQuestion">
    <view class="modal-box" catchtap="noop">
      <text class="modal-title">填写你的问题</text>
      <textarea
        class="modal-input"
        placeholder="请描述你的疑问或顾虑"
        value="{{questionInput}}"
        bindinput="onQuestionInput"
        maxlength="200"
      />
      <view class="modal-actions">
        <button class="ghost-btn" bindtap="onCloseQuestion">取消</button>
        <button class="primary-btn" bindtap="onSubmitQuestion">提交</button>
      </view>
    </view>
  </view>
</view>
