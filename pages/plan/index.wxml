<view class="page">

  <!-- ─── 状态：无方案 ─── -->
  <block wx:if="{{pageState === 'empty'}}">
    <view class="empty-state">
      <view class="empty-icon-box">
        <view class="empty-icon-inner">
          <text class="empty-icon-text">方</text>
        </view>
      </view>
      <text class="empty-title">当前还没有生效中的管理方案</text>
      <text class="empty-desc">医生确认并下发后，你可以在这里查看当前方案和最近安排</text>
      <button class="btn-primary" bindtap="goScreening">去完成健康筛查</button>
    </view>
  </block>

  <!-- ─── 状态：待确认 ─── -->
  <block wx:elif="{{pageState === 'pending_confirm'}}">
    <view class="confirm-page">

      <!-- 提示横幅 -->
      <view class="notify-banner">
        <view class="banner-dot"></view>
        <view class="banner-body">
          <text class="banner-title">医生已为您制定管理方案</text>
          <text class="banner-sub">请阅读方案内容后确认执行</text>
        </view>
      </view>

      <!-- 方案头卡 -->
      <view class="card plan-header-card">
        <view class="plan-header-top">
          <text class="plan-name">{{plan.title}}</text>
          <view class="badge badge-pending">待确认</view>
        </view>
        <text class="plan-meta">适用疾病：{{plan.disease}}　主责医生：{{plan.doctor}}</text>
        <text class="plan-meta">周期：{{plan.period.days}} 天</text>
        <view class="plan-objective-box">
          <text class="plan-objective-label">本阶段目标</text>
          <text class="plan-objective-text">{{plan.objective}}</text>
        </view>
      </view>

      <!-- 方案明细（待确认态默认全部展开） -->
      <view class="section-block">
        <text class="section-title">指标测量</text>
        <view class="item-list">
          <view wx:for="{{plan.modules}}" wx:key="key">
            <block wx:if="{{item.key === 'metrics' && item.items}}">
              <view wx:for="{{item.items}}" wx:for-item="line" wx:key="index" class="item-row">
                <view class="item-dot"></view>
                <text>{{line}}</text>
              </view>
            </block>
          </view>
        </view>
      </view>

      <view wx:for="{{plan.modules}}" wx:key="key">
        <block wx:if="{{item.key === 'lifestyle' && item.items}}">
          <view class="section-block">
            <text class="section-title">生活方式</text>
            <view class="item-list">
              <view wx:for="{{item.items}}" wx:for-item="line" wx:key="index" class="item-row">
                <view class="item-dot lifestyle-dot"></view>
                <text>{{line}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>

      <view wx:for="{{plan.modules}}" wx:key="key">
        <block wx:if="{{item.key === 'medication' && item.items}}">
          <view class="section-block">
            <text class="section-title">用药配合</text>
            <view class="item-list">
              <view wx:for="{{item.items}}" wx:for-item="line" wx:key="index" class="item-row">
                <view class="item-dot med-dot"></view>
                <text>{{line}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>

      <!-- 异常提示 -->
      <view wx:if="{{plan.abnormalTips}}" class="abnormal-tips">
        <view class="tips-icon">!</view>
        <text>{{plan.abnormalTips}}</text>
      </view>

      <!-- 吸底确认按钮 -->
      <view class="confirm-actions">
        <button class="btn-ghost" bindtap="onQuestionTap">我有疑问</button>
        <button class="btn-primary" bindtap="onConfirmPlan">我已知晓，开始执行</button>
      </view>

    </view>
  </block>

  <!-- ─── 状态：执行中（连续信息流） ─── -->
  <block wx:elif="{{pageState === 'active'}}">
    <view class="active-page">

      <!-- 1. 当前方案头卡 -->
      <view class="card plan-header-card">
        <view class="plan-header-top">
          <text class="plan-name">{{plan.title}}</text>
          <view class="badge badge-active">执行中</view>
        </view>
        <text class="plan-stage">{{plan.objective}}</text>
        <view class="plan-meta-row">
          <text class="plan-meta">主责医生：{{plan.doctor}}</text>
          <text class="plan-meta">适用疾病：{{plan.disease}}</text>
        </view>
        <view class="plan-meta-row">
          <text class="plan-meta">已生效：{{plan.period.startDate}}</text>
          <text class="plan-meta">周期：{{plan.period.days}} 天</text>
        </view>
      </view>

      <!-- 2. 最近安排 -->
      <view class="section-block">
        <text class="section-title">最近安排</text>

        <!-- 空状态 -->
        <view wx:if="{{!adviceList.length && !recheckPlans.length && !activeFollowups.length}}" class="empty-section">
          <text class="empty-section-text">当前没有新的安排</text>
        </view>

        <!-- 医生建议卡片 -->
        <view wx:for="{{adviceList}}" wx:key="id" class="card advice-card" bindtap="onAdviceTap" data-id="{{item.id}}">
          <view class="advice-header">
            <view class="advice-icon">医</view>
            <text class="advice-from">{{item.doctorName}}</text>
            <view class="badge {{item.status === 'sent' ? 'badge-unread' : 'badge-read'}}">
              {{item.status === 'sent' ? '未读' : '已读'}}
            </view>
          </view>
          <text class="advice-title">{{item.title}}</text>
          <text class="advice-summary">{{item.content}}</text>
          <text class="advice-time">{{item.sentAt}}</text>
          <view class="card-action-btn">查看</view>
        </view>

        <!-- 复测指标卡片 -->
        <view wx:for="{{recheckPlans}}" wx:key="id" class="card recheck-card">
          <view class="recheck-header">
            <view class="recheck-icon">测</view>
            <text class="recheck-title">复测指标</text>
            <view class="badge badge-temp">临时安排</view>
          </view>
          <text class="recheck-summary">{{recheckProgress[item.id].summary}}</text>
          <text class="recheck-instruction">{{item.patientInstruction}}</text>
          <view class="recheck-progress-row">
            <text class="recheck-status">{{recheckProgress[item.id].taskStatus}}</text>
            <text wx:if="{{recheckProgress[item.id].daysRemaining > 0}}" class="recheck-remaining">还需完成 {{recheckProgress[item.id].daysRemaining}} 天</text>
          </view>
          <view class="card-action-btn" bindtap="onRecheckAction" data-id="{{item.id}}">去记录</view>
        </view>

        <!-- 随访安排卡片（最近安排区内） -->
        <view wx:for="{{activeFollowups}}" wx:key="id" class="card followup-card">
          <view class="followup-header">
            <view class="followup-icon">随</view>
            <text class="followup-title">随访安排</text>
          </view>
          <text class="followup-time">{{item.dueAt}}</text>
          <view class="followup-method-tag">{{item.method}}</view>
          <text wx:if="{{item.patientInstruction}}" class="followup-instruction">{{item.patientInstruction}}</text>
          <view class="card-action-btn" bindtap="onFollowupPrepareTap" data-id="{{item.id}}">查看准备项</view>
        </view>

        <view wx:if="{{adviceList.length || recheckPlans.length || activeFollowups.length}}" class="section-link-row">
          <view class="ghost-link" bindtap="onGoAdviceHistory">查看历史医生建议</view>
        </view>

      </view>

      <!-- 2A. 随访记录入口 -->
      <view class="section-block">
        <view class="section-head-inline">
          <text class="section-title">随访安排</text>
          <view class="ghost-link" bindtap="onGoFollowupRecords">查看全部随访</view>
        </view>
        <view wx:if="{{nearestFollowup}}" class="card followup-current-card" bindtap="onGoFollowupRecords">
          <view class="followup-header">
            <view class="followup-icon">随</view>
            <text class="followup-title">{{nearestFollowup.title}}</text>
          </view>
          <text class="followup-time">{{nearestFollowup.dueAt}}</text>
          <text class="followup-instruction">{{nearestFollowup.patientInstruction}}</text>
          <view class="card-action-btn">查看全部随访</view>
        </view>
        <view wx:else class="empty-section">
          <text class="empty-section-text">当前没有需要准备的随访</text>
          <view class="ghost-link" bindtap="onGoFollowupRecords">查看全部随访</view>
        </view>
      </view>

      <!-- 3. 今日任务轻入口 -->
      <view class="card today-task-card" bindtap="onGoHomeTasks">
        <view class="today-task-header">
          <text class="today-task-title">今日任务</text>
        </view>
        <text wx:if="{{totalCount > 0 && doneCount < totalCount}}" class="today-task-desc">今日有 {{totalCount - doneCount}} 项待完成，已完成 {{doneCount}} 项</text>
        <text wx:elif="{{totalCount > 0 && doneCount === totalCount}}" class="today-task-desc today-task-done">今天的任务已完成</text>
        <text wx:else class="today-task-desc">今日暂无任务</text>
        <view class="card-action-btn">去今日任务</view>
      </view>

      <!-- 4. 方案明细（下沉内容） -->
      <view class="section-block detail-section">
        <text class="section-title">方案明细</text>

        <!-- 指标测量 -->
        <view wx:if="{{compiledMetrics.length}}" class="detail-group">
          <text class="detail-group-title">指标测量</text>
          <view wx:for="{{compiledMetrics}}" wx:key="index" class="detail-item">
            <view class="detail-dot metric-dot"></view>
            <text>{{item}}</text>
          </view>
        </view>

        <!-- 生活方式 -->
        <view wx:if="{{compiledLifestyle.length}}" class="detail-group">
          <text class="detail-group-title">生活方式</text>
          <view wx:for="{{compiledLifestyle}}" wx:key="index" class="detail-item">
            <view class="detail-dot lifestyle-dot"></view>
            <text>{{item}}</text>
          </view>
        </view>

        <!-- 用药配合 -->
        <view wx:if="{{compiledMedication}}" class="detail-group">
          <text class="detail-group-title">用药配合</text>
          <view wx:for="{{compiledMedication}}" wx:for-item="line" wx:key="index" class="detail-item">
            <view class="detail-dot med-dot"></view>
            <text>{{line}}</text>
          </view>
        </view>

        <!-- 设备配合 -->
        <view wx:if="{{compiledDevice}}" class="detail-group">
          <text class="detail-group-title">设备配合</text>
          <view wx:for="{{compiledDevice}}" wx:for-item="line" wx:key="index" class="detail-item">
            <view class="detail-dot device-dot"></view>
            <text>{{line}}</text>
          </view>
        </view>

        <!-- 随访节奏 -->
        <view wx:if="{{compiledFollowupPace}}" class="detail-group">
          <text class="detail-group-title">随访安排</text>
          <view wx:for="{{compiledFollowupPace}}" wx:for-item="line" wx:key="index" class="detail-item">
            <view class="detail-dot followup-dot"></view>
            <text>{{line}}</text>
          </view>
        </view>
      </view>

      <!-- 5. 阶段说明 -->
      <view wx:if="{{stageGoal || dailyToDo.length || abnormalHandling}}" class="section-block">
        <text class="section-title">阶段说明</text>
        <view wx:if="{{stageGoal}}" class="detail-item">
          <view class="detail-dot"></view>
          <text>{{stageGoal}}</text>
        </view>
        <view wx:for="{{dailyToDo}}" wx:key="index" class="detail-item">
          <view class="detail-dot"></view>
          <text>{{item}}</text>
        </view>
        <view wx:if="{{abnormalHandling}}" class="detail-item abnormal-item">
          <view class="detail-dot warn-dot"></view>
          <text>{{abnormalHandling}}</text>
        </view>
      </view>

      <view class="section-block bottom-links-block">
        <view class="ghost-link" bindtap="onGoHistoryPlans">查看历史方案</view>
      </view>

    </view>
  </block>

  <!-- ─── 疑问弹窗 ─── -->
  <view wx:if="{{showQuestionModal}}" class="modal-mask" bindtap="onCloseQuestion">
    <view class="modal-box" catchtap="noop">
      <text class="modal-title">填写你的问题</text>
      <textarea
        class="modal-input"
        placeholder="请描述您的疑问或顾虑…"
        value="{{questionInput}}"
        bindinput="onQuestionInput"
        maxlength="200"
        auto-focus
      />
      <view class="modal-actions">
        <button class="btn-ghost" bindtap="onCloseQuestion">取消</button>
        <button class="btn-primary" bindtap="onSubmitQuestion">提交</button>
      </view>
    </view>
  </view>

  <!-- ─── 建议详情抽屉 ─── -->
  <view wx:if="{{showAdviceDrawer}}" class="modal-mask" bindtap="onAdviceClose">
    <view class="modal-box advice-drawer-box" catchtap="noop">
      <view class="advice-drawer-header">
        <view class="drawer-icon">医</view>
        <text class="drawer-doctor">{{currentAdvice.doctorName}}</text>
        <text class="drawer-time">{{currentAdvice.sentAt}}</text>
      </view>
      <text class="drawer-title">{{currentAdvice.title}}</text>
      <text class="drawer-content">{{currentAdvice.content}}</text>
      <view class="drawer-status {{currentAdvice.status === 'read' ? 'is-read' : 'is-unread'}}">
        {{currentAdvice.status === 'read' ? '已读' : '未读'}}
      </view>
      <view class="modal-actions">
        <button class="btn-ghost" bindtap="onAdviceClose">关闭</button>
      </view>
    </view>
  </view>

</view>
