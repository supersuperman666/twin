.page {
  min-height: 100vh;
  background: #EEF2F6;
  padding: 24rpx 24rpx 48rpx;
}

.group-section {
  margin-bottom: 32rpx;
}

.group-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.group-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #16202D;
}

.group-count {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #E9F3FF;
  color: #237BE8;
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.timeline-item {
  display: flex;
  gap: 16rpx;
}

.timeline-side {
  width: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-top: 24rpx;
}

.timeline-dot.active {
  background: #F59E0B;
  box-shadow: 0 0 0 6rpx rgba(245, 158, 11, 0.18);
}

.timeline-dot.finished {
  background: #9AA7B5;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  background: #DDE5EE;
}

.timeline-main {
  flex: 1;
  padding-bottom: 20rpx;
}

.follow-card,
.empty-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #E7ECF2;
  padding: 28rpx;
}

.empty-text {
  color: #6D7A89;
  font-size: 26rpx;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.time-text {
  display: block;
  color: #7D8896;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.card-title {
  display: block;
  color: #16202D;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.card-sub {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #E9F3FF;
  color: #237BE8;
  font-size: 22rpx;
  font-weight: 700;
}

.card-desc {
  display: block;
  margin-top: 16rpx;
  color: #506070;
  font-size: 25rpx;
  line-height: 1.6;
}

.status-badge {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-badge.pending {
  background: #FFF4DB;
  color: #D97706;
}

.status-badge.partial {
  background: #E9F3FF;
  color: #237BE8;
}

.status-badge.ready {
  background: #E8F8F1;
  color: #0E9F6E;
}

.status-badge.finished {
  background: #EDF2F8;
  color: #627084;
}

.expand-body {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #EEF2F6;
}

.sub-section + .sub-section {
  margin-top: 20rpx;
}

.sub-title {
  display: block;
  color: #16202D;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.bullet-row {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.bullet {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #237BE8;
  margin-top: 14rpx;
}

.bullet-row text,
.result-text {
  flex: 1;
  color: #425063;
  font-size: 25rpx;
  line-height: 1.6;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #F6F8FB;
  margin-bottom: 12rpx;
}

.action-label {
  display: block;
  color: #16202D;
  font-size: 25rpx;
  font-weight: 700;
}

.action-state {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
}

.action-state.pending {
  color: #D97706;
}

.action-state.done {
  color: #0E9F6E;
}

.action-btn,
.done-tag {
  flex: none;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.action-btn {
  background: #237BE8;
  color: #FFFFFF;
}

.done-tag {
  background: #E8F8F1;
  color: #0E9F6E;
}
