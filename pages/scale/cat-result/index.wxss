/* ─── 页面基础 ─── */
page { background: #EEF2F6; }

.page {
  min-height: 100vh;
  background: #EEF2F6;
  padding: 24rpx 32rpx 120rpx;
  color: #16202D;
}

/* ─── 评分卡片 ─── */
.score-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 2rpx solid #E7ECF2;
  padding: 40rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.score-label {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #5D6A7A;
  margin-bottom: 16rpx;
}

.score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
}

.score-number {
  font-size: 96rpx;
  font-weight: 900;
  line-height: 1;
}

.score-max {
  font-size: 32rpx;
  font-weight: 700;
  color: #8D99A8;
}

/* ─── 影响等级色带 ─── */
.bar-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 2rpx solid #E7ECF2;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.bar-container {
  display: flex;
  height: 48rpx;
  border-radius: 24rpx;
  overflow: hidden;
  gap: 4rpx;
}

.bar-segment {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  opacity: 0.5;
  transition: opacity 0.3s;
}

.bar-active {
  opacity: 1;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.bar-label {
  font-size: 22rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.bar-indicator-row {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.bar-min, .bar-max {
  font-size: 22rpx;
  color: #8D99A8;
  font-weight: 700;
}

/* ─── 影响等级 ─── */
.level-content {
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 2rpx solid #E7ECF2;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.level-badge-row {
  margin-bottom: 16rpx;
}

.level-badge {
  display: inline-flex;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.level-desc {
  display: block;
  font-size: 28rpx;
  color: #3A4A5A;
  line-height: 1.7;
  font-weight: 700;
}

/* ─── 信息卡片 ─── */
.info-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  border: 2rpx solid #E7ECF2;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.info-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 12rpx;
}

.info-text {
  display: block;
  font-size: 26rpx;
  color: #5D6A7A;
  line-height: 1.6;
  font-weight: 700;
}

/* ─── 操作按钮 ─── */
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-detail {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  background: #E9F3FF;
  color: #1F82FF;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border: 0;
}

.btn-detail::after { border: 0; }

.btn-home {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  background: #1F82FF;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(31, 130, 255, 0.2);
  border: 0;
}

.btn-home::after { border: 0; }