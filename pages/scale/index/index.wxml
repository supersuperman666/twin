<view class="page">

  <view class="page-header">
    <text class="page-title">评估量表</text>
    <view class="history-link" bindtap="goHistory">评估记录</view>
  </view>

  <view class="scale-list">
    <view wx:for="{{scales}}" wx:key="code" class="scale-card" bindtap="onScaleTap" data-code="{{item.code}}" data-route="{{item.route}}">
      <view class="scale-card-top">
        <view class="scale-icon" style="background: {{item.color}};">
          <text class="scale-icon-text">{{item.icon}}</text>
        </view>
        <view class="scale-card-info">
          <text class="scale-name">{{item.name}}</text>
          <text class="scale-full-name">{{item.fullName}}</text>
          <text class="scale-desc">{{item.desc}}</text>
        </view>
      </view>
      <view class="scale-card-bottom">
        <view class="scale-meta-row">
          <text class="scale-meta">{{item.questionsCount}} 题</text>
          <text class="scale-meta">{{item.timeEstimate}}</text>
        </view>
        <view wx:if="{{item.hasHistory}}" class="scale-status-row">
          <view class="badge" style="background: {{item.statusColor}}; color: #FFFFFF;">{{item.statusLabel}}</view>
          <text class="scale-last-score">{{item.lastScoreText}}</text>
          <text class="scale-last-date">{{item.lastDate}}</text>
        </view>
        <view wx:else class="scale-status-row">
          <view class="badge badge-pending">{{item.statusLabel}}</view>
        </view>
      </view>
    </view>
  </view>

</view>