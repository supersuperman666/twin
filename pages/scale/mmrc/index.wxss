/* ─── 页面基础 ─── */
page { background: #EEF2F6; }

.page {
  min-height: 100vh;
  background: #EEF2F6;
  padding: 0 32rpx;
  color: #16202D;
  display: flex;
  flex-direction: column;
}

/* ─── 标题区 ─── */
.header {
  padding: 32rpx 0 24rpx;
}

.header-badge {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #EF4444;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.header-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #16202D;
  margin-bottom: 8rpx;
}

.header-text {
  display: block;
  font-size: 28rpx;
  color: #5D6A7A;
  line-height: 1.6;
}

/* ─── 选项列表 ─── */
.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E7ECF2;
  transition: all 0.2s ease;
}

.option-selected {
  background: #FDE8E8;
  border-color: #EF4444;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.12);
}

.option-grade-badge {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  border-radius: 16rpx;
  background: #EDF2F8;
  color: #627084;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-selected .option-grade-badge {
  background: #EF4444;
  color: #FFFFFF;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #3A4A5A;
  line-height: 1.4;
}

.option-selected .option-text {
  color: #16202D;
}

.option-check {
  width: 36rpx;
  height: 36rpx;
  flex: 0 0 36rpx;
  border-radius: 50%;
  background: #EF4444;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.option-check::after {
  content: '';
  width: 16rpx;
  height: 10rpx;
  border-left: 3rpx solid #FFFFFF;
  border-bottom: 3rpx solid #FFFFFF;
  transform: rotate(-45deg);
  position: absolute;
  top: 10rpx;
  left: 10rpx;
}

/* ─── 底部 ─── */
.bottom-nav {
  display: flex;
  padding: 32rpx 0 calc(env(safe-area-inset-bottom) + 32rpx);
  margin-top: auto;
}

.nav-back {
  width: 100%;
  height: 88rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid #E7ECF2;
  color: #425063;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}