<view class="page">
  <view class="nav-row">
    <view class="back" bindtap="goBack">‹</view>
    <text class="nav-title">血压详情</text>
    <view class="nav-space"></view>
  </view>

  <view class="hero">
    <text class="hero-label">最新血压 · 晨起 · 05.17 08:10</text>
    <view class="hero-main">
      <view><text class="hero-value">120/90</text><text class="hero-unit">mmHg</text></view>
      <text class="hero-badge">正常</text>
    </view>
    <text class="hero-label">近 7 天血压整体平稳，建议继续晨起和睡前记录。</text>
  </view>

  <view class="chart-card">
    <view class="chart-head"><text class="chart-title">血压趋势</text><text class="link">近7天</text></view>
    <view class="summary-grid">
      <view class="summary-item"><text class="summary-label">平均</text><text class="summary-value">126/86</text></view>
      <view class="summary-item"><text class="summary-label">最高</text><text class="summary-value">138/92</text></view>
      <view class="summary-item"><text class="summary-label">异常</text><text class="summary-value">0次</text></view>
    </view>
    <view class="line-chart"><view class="line"></view></view>
  </view>

  <view class="section-head">
    <text class="section-title">最近记录</text>
    <text class="link" bindtap="goHistory">查看全部</text>
  </view>
  <view wx:for="{{records}}" wx:key="time" class="list-card">
    <view class="list-top">
      <view><text class="list-title">{{item.value}}</text><text class="list-desc">{{item.time}} · {{item.scene}}</text></view>
      <text class="tag">{{item.status}}</text>
    </view>
  </view>
  <view class="bottom-action" bindtap="goForm">新增血压记录</view>
</view>
