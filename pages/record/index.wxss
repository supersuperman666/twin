page {
  background: #f6f7f9;
}

.page {
  min-height: 100vh;
  padding: 20rpx 32rpx 156rpx;
  background: #f6f7f9;
  color: #15181d;
}

.record-topbar {
  margin: 6rpx 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.device-entry {
  height: 56rpx;
  padding: 0 20rpx 0 44rpx;
  border-radius: 28rpx;
  color: #237be8;
  background: #e9f3ff;
  display: flex;
  align-items: center;
  position: relative;
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
}

.device-entry::before {
  content: "";
  position: absolute;
  left: 18rpx;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #237be8;
  border-radius: 5rpx;
}

.date-card {
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.calendar-icon {
  width: 30rpx;
  height: 30rpx;
  flex: 0 0 30rpx;
  position: relative;
  border: 4rpx solid #2478ff;
  border-radius: 7rpx;
  box-sizing: border-box;
}

.calendar-icon::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: 6rpx;
  height: 4rpx;
  background: #2478ff;
}

.calendar-icon::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: -8rpx;
  width: 10rpx;
  height: 8rpx;
  border-left: 4rpx solid #2478ff;
  border-right: 4rpx solid #2478ff;
}

.date-main {
  color: #2a2f37;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1;
}

.date-week {
  min-width: 56rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  color: #667085;
  background: #eef2f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.date-actions {
  display: flex;
  gap: 14rpx;
}

.date-actions button {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #f7f8fa;
  color: #1f2937;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
}

.tabs {
  position: sticky;
  top: 0;
  z-index: 20;
  margin: 22rpx -32rpx 26rpx;
  padding: 12rpx 0;
  background: #f6f7f9;
  white-space: nowrap;
}

.tabs-inner {
  padding: 0 32rpx;
  display: flex;
  gap: 14rpx;
  width: max-content;
}

.anchor-pill {
  width: auto;
  min-width: 96rpx;
  height: 66rpx;
  padding: 0 24rpx;
  border-radius: 34rpx;
  background: #eceef2;
  color: #626a76;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
  flex: 0 0 auto;
  box-sizing: border-box;
}

.anchor-pill.active {
  color: #ffffff;
  background: #2f7df6;
}

.section-title {
  margin: 30rpx 0 18rpx;
  color: #1f2937;
  font-size: 29rpx;
  font-weight: 800;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
}

.metric-card,
.record-card {
  border-radius: 18rpx;
  background: #ffffff;
}

.metric-card {
  position: relative;
  min-height: 214rpx;
  padding: 26rpx 30rpx;
}

.metric-card.wide {
  grid-column: span 2;
  min-height: 232rpx;
}

.metric-card.bmi {
  min-height: 202rpx;
}

.card-head,
.title-row,
.record-top,
.medicine-main {
  display: flex;
  align-items: center;
}

.card-head,
.record-top,
.medicine-main {
  justify-content: space-between;
}

.card-head {
  min-height: 50rpx;
  padding-right: 68rpx;
}

.title-row {
  min-width: 0;
  gap: 12rpx;
  flex-wrap: wrap;
}

.metric-title {
  color: #20242a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.18;
}

.inline-value {
  color: #20242a;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.tag {
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 7rpx;
  color: #2478ff;
  background: #e8f2ff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
  white-space: nowrap;
}

.tag.warning {
  color: #ee9500;
  background: #fff0c7;
}

.plus-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 50rpx;
  height: 50rpx;
  min-width: 50rpx;
  margin: 0;
  padding: 0;
  flex: 0 0 54rpx;
  border: 4rpx solid #cfd6e0;
  border-radius: 50%;
  color: #667085;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
  box-sizing: border-box;
}

.plus-btn::after {
  border: 0;
}

.time {
  display: block;
  margin-top: 16rpx;
  color: #98a2b3;
  font-size: 25rpx;
  font-weight: 400;
  line-height: 1.15;
}

.value-row {
  margin-top: 30rpx;
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.metric-card.bmi .value-row {
  display: none;
}

.metric-value {
  color: #111827;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.unit {
  margin-left: 8rpx;
  color: #98a2b3;
  font-size: 24rpx;
  font-weight: 700;
}

.inline-note {
  margin-left: auto;
  color: #6b7280;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
}

.child-row {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.metric-card.bmi .child-row {
  margin-top: 28rpx;
}

.child-label {
  display: inline-block;
  margin-right: 10rpx;
  margin-bottom: 0;
  color: #6b7280;
  font-size: 28rpx;
  font-weight: 800;
}

.child-value {
  color: #111827;
  font-size: 36rpx;
  font-weight: 700;
}

.child-unit {
  margin-left: 8rpx;
  color: #98a2b3;
  font-size: 23rpx;
  font-weight: 700;
}

.section-head {
  margin: 34rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.section-head text {
  color: #20242a;
  font-size: 30rpx;
  font-weight: 800;
  flex: 1;
}

.section-head button {
  width: auto;
  min-width: 0;
  margin: 0;
  padding: 0;
  color: #2478ff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1;
  text-align: right;
  flex: 0 0 auto;
}

.section-head button::after {
  border: 0;
}

.record-card {
  padding: 30rpx;
}

.record-time {
  color: #6b7280;
  font-size: 25rpx;
  font-weight: 400;
}

.level-tag,
.medicine-status {
  height: 34rpx;
  padding: 0 14rpx;
  border-radius: 7rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 900;
}

.level-tag {
  color: #f59e0b;
  background: #fff0c7;
}

.record-title {
  display: block;
  margin-top: 28rpx;
  color: #1b1f25;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.record-desc {
  display: block;
  margin-top: 10rpx;
  color: #98a2b3;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
}

.empty-other {
  height: 168rpx;
  color: #a4adba;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 25rpx;
  font-weight: 800;
}

.empty-doc {
  color: #cfd6df;
  font-size: 56rpx;
  line-height: 1;
}

.medicine-card {
  margin-top: 20rpx;
}

.medicine-status.done {
  color: #07a66d;
  background: #dffbea;
}

.medicine-status.pending {
  color: #667085;
  background: #f0f2f5;
}

.medicine-main {
  margin-top: 28rpx;
}

.medicine-main .record-title {
  margin-top: 0;
}

.dose {
  color: #2478ff;
  font-size: 26rpx;
  font-weight: 900;
}

.detail-link {
  color: #237be8;
  font-size: 26rpx;
  font-weight: 900;
}

.sleep-report-card {
  padding: 28rpx;
  border: 2rpx solid #e5efff;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f3f8ff 100%);
}

.sleep-report-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.sleep-summary {
  margin: 22rpx 0;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.sleep-summary-item {
  padding: 16rpx 14rpx;
  border: 2rpx solid #edf2f8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .78);
}

.sleep-value {
  display: block;
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.sleep-value.warning {
  color: #f59e0b;
}

.sleep-label {
  display: block;
  margin-top: 8rpx;
  color: #8a96a8;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.25;
}

.sleep-note {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  color: #627084;
  background: #f3f6fb;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}
