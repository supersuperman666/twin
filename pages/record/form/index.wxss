@import "../common.wxss";

.page {
  min-height: 100vh;
  padding: 0 0 56rpx;
  background: #f7f8fa;
}

.point-tabs {
  height: 142rpx;
  border-bottom: 14rpx solid #f1f2f4;
  background: #ffffff;
  white-space: nowrap;
}

.point-tabs-inner {
  display: inline-flex;
  min-width: 100%;
  height: 128rpx;
  align-items: center;
  padding: 0 34rpx;
  gap: 44rpx;
}

.point-tab {
  position: relative;
  min-width: 86rpx;
  height: 104rpx;
  color: #8a8f98;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 800;
  white-space: nowrap;
}

.point-tab.active {
  color: #2f91f3;
}

.point-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 42rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #2f91f3;
  transform: translateX(-50%);
}

.point-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.glucose-picker {
  height: 444rpx;
  padding: 48rpx 44rpx 36rpx;
  border-bottom: 1rpx solid #edf0f4;
  background: #ffffff;
  text-align: center;
}

.range-copy {
  color: #a0a4ab;
  font-size: 30rpx;
  font-weight: 500;
}

.value-edit {
  margin: 42rpx auto 14rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.value-edit.compact {
  margin: 14rpx auto 28rpx;
}

.value-input {
  width: 150rpx;
  height: 78rpx;
  color: #2f91f3;
  font-size: 62rpx;
  font-weight: 800;
  line-height: 78rpx;
  text-align: center;
}

.picker-unit {
  margin-left: 10rpx;
  margin-bottom: 10rpx;
  color: #b1b6bf;
  font-size: 26rpx;
  font-weight: 600;
}

.ruler-box {
  position: relative;
  height: 128rpx;
  margin: 0 auto;
  padding-top: 20rpx;
}

.tick-row {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 32rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  pointer-events: none;
}

.tick {
  width: 4rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #b8bdc5;
}

.tick.mid {
  height: 30rpx;
}

.tick.large {
  height: 42rpx;
  background: #a7adb7;
}

.real-slider {
  position: relative;
  z-index: 2;
  margin: 42rpx 0 0;
}

.center-marker {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 0;
  border-left: 13rpx solid transparent;
  border-right: 13rpx solid transparent;
  border-bottom: 0;
  border-top: 22rpx solid #2f91f3;
  transform: translateX(-50%);
  pointer-events: none;
}

.slider-meta {
  margin-top: 18rpx;
  color: #b1b6bf;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 22rpx;
}

.form-list {
  margin-top: 18rpx;
  background: #ffffff;
}

.form-row {
  min-height: 112rpx;
  padding: 0 34rpx;
  border-bottom: 1rpx solid #eef0f3;
  color: #2f3338;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: 500;
}

.row-value {
  color: #737982;
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 32rpx;
  font-weight: 400;
}

.chevron {
  color: #c7cbd1;
  font-size: 46rpx;
  font-weight: 300;
}

.status-value {
  font-size: 32rpx;
  font-weight: 600;
}

.status-value.normal {
  color: #8bc34a;
}

.status-value.low,
.status-value.high {
  color: #f59e0b;
}

.remark-row {
  padding: 32rpx 34rpx;
  border-bottom: 1rpx solid #eef0f3;
}

.remark-head {
  margin-bottom: 18rpx;
  color: #2f3338;
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: 500;
}

.remark-count {
  color: #b1b6bf;
  font-size: 24rpx;
  font-weight: 400;
}

.remark-input {
  width: 100%;
  min-height: 92rpx;
  padding: 20rpx 22rpx;
  border-radius: 14rpx;
  background: #f6f7f9;
  color: #303640;
  font-size: 28rpx;
  line-height: 1.45;
}

.remark-placeholder {
  color: #b1b6bf;
}

.submit-btn {
  height: 88rpx;
  margin: 34rpx 30rpx 0;
  border-radius: 10rpx;
  color: #ffffff;
  background: #2f91f3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.picker-card {
  margin: 24rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.field-label {
  display: block;
  color: #667085;
  font-size: 27rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.range-tip {
  display: block;
  margin-top: 18rpx;
  color: #8a96a8;
  font-size: 24rpx;
}
