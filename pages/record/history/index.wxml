<view class="page">
  <view class="date-range-card">
    <view class="date-range-head">
      <view class="date-title-row">
        <view class="calendar-icon-small"></view>
        <text>记录时间</text>
      </view>
      <text class="range-hint">最多30天</text>
    </view>
    <view class="date-picker-row">
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="date-picker">
          <text class="date-label">开始日期</text>
          <text class="date-value">{{startDate}}</text>
        </view>
      </picker>
      <text class="date-separator">至</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="date-picker">
          <text class="date-label">结束日期</text>
          <text class="date-value">{{endDate}}</text>
        </view>
      </picker>
    </view>
    <view class="date-summary">{{dateRangeText}} · 共{{summary.total}}条</view>
  </view>

  <block wx:for="{{dayGroups}}" wx:key="day" wx:for-item="group">
    <view class="day-title">{{group.day}} <text>{{group.count}}条</text></view>
    <view wx:for="{{group.items}}" wx:key="id" wx:for-item="item" class="history-item" data-id="{{item.id}}" bindtap="openDrawer">
      <view class="history-main">
        <view>
          <text class="history-title">{{item.title}}</text>
          <view class="history-meta">
            <text>{{item.time}}</text>
            <text class="source {{item.sourceType}}">{{item.source}}</text>
            <text wx:if="{{item.device}}">SN {{item.device}}</text>
          </view>
        </view>
        <view class="history-value"><text>{{item.value}}</text><text class="unit">{{item.unit}}</text></view>
      </view>
      <view class="history-meta"><text class="tag">{{item.status}}</text><text>{{item.remark}}</text></view>
    </view>
  </block>

  <view wx:if="{{!dayGroups.length}}" class="empty-state">
    <view class="empty-icon"></view>
    <text>当前时间范围暂无记录</text>
    <text class="empty-desc">可调整开始日期或结束日期查看</text>
  </view>

  <view wx:if="{{drawerVisible}}" class="drawer-mask" bindtap="closeDrawer">
    <view class="drawer" catchtap="noop">
      <view class="handle"></view>
      <view class="drawer-head">
        <view>
          <text class="drawer-title">记录详情</text>
          <text class="list-desc">单条记录完整信息</text>
        </view>
        <text class="tag">{{selectedRecord.status}}</text>
      </view>
      <view class="detail-line"><text>指标值</text><text>{{selectedRecord.value}} {{selectedRecord.unit}}</text></view>
      <view class="detail-line"><text>记录时间</text><text>{{selectedRecord.fullTime}}</text></view>
      <view class="detail-line"><text>记录场景</text><text>{{selectedRecord.title}}</text></view>
      <view class="detail-line"><text>数据来源</text><text>{{selectedRecord.source}}</text></view>
      <view wx:if="{{selectedRecord.device}}" class="detail-line"><text>设备号</text><text>{{selectedRecord.device}}</text></view>
      <view class="detail-line"><text>备注</text><text>{{selectedRecord.remark}}</text></view>
      <view class="detail-line"><text>修改信息</text><text>{{selectedRecord.edited}}</text></view>
      <view class="drawer-actions">
        <view class="outline-action" bindtap="handlePrimaryAction">{{selectedRecord.sourceType == 'device' ? '添加备注' : '编辑记录'}}</view>
        <view class="danger-action" bindtap="handleDangerAction">{{selectedRecord.sourceType == 'device' ? '标记无效' : '删除记录'}}</view>
      </view>
    </view>
  </view>
</view>
