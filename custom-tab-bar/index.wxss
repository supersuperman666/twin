.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1rpx solid rgba(20, 37, 32, 0.08);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(31, 41, 55, 0.04);
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #7f8a99;
  font-size: 22rpx;
  font-weight: 700;
}

.tabbar-item.active {
  color: #237be8;
}

.tabbar-icon {
  position: relative;
  width: 46rpx;
  height: 46rpx;
  color: currentColor;
}

.tabbar-icon::before,
.tabbar-icon::after,
.icon-mark,
.icon-mark::before,
.icon-mark::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.icon-home::before {
  left: 8rpx;
  top: 6rpx;
  width: 30rpx;
  height: 30rpx;
  border-left: 5rpx solid currentColor;
  border-top: 5rpx solid currentColor;
  border-radius: 4rpx 0 0 0;
  transform: rotate(45deg);
}

.icon-home .icon-mark {
  left: 11rpx;
  top: 19rpx;
  width: 24rpx;
  height: 20rpx;
  border: 5rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 6rpx 6rpx;
  background: #ffffff;
}

.icon-record .icon-mark {
  left: 12rpx;
  top: 6rpx;
  width: 24rpx;
  height: 34rpx;
  border: 5rpx solid currentColor;
  border-radius: 5rpx;
}

.icon-record .icon-mark::before {
  left: 5rpx;
  top: 8rpx;
  width: 10rpx;
  height: 5rpx;
  border-top: 4rpx solid currentColor;
}

.icon-record .icon-mark::after {
  left: 5rpx;
  top: 18rpx;
  width: 10rpx;
  height: 5rpx;
  border-top: 4rpx solid currentColor;
}

.icon-plan .icon-mark {
  left: 9rpx;
  top: 9rpx;
  width: 28rpx;
  height: 30rpx;
  border: 5rpx solid currentColor;
  border-radius: 6rpx;
}

.icon-plan::before,
.icon-plan::after {
  top: 5rpx;
  width: 5rpx;
  height: 10rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.icon-plan::before {
  left: 16rpx;
}

.icon-plan::after {
  right: 16rpx;
}

.icon-plan .icon-mark::before {
  left: 6rpx;
  right: 6rpx;
  top: 10rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
}

.icon-user::before {
  left: 15rpx;
  top: 6rpx;
  width: 16rpx;
  height: 16rpx;
  border: 5rpx solid currentColor;
  border-radius: 50%;
}

.icon-user .icon-mark {
  left: 9rpx;
  top: 28rpx;
  width: 28rpx;
  height: 13rpx;
  border: 5rpx solid currentColor;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 0 0;
}

.tabbar-item.active .icon-home .icon-mark,
.tabbar-item.active .icon-record .icon-mark,
.tabbar-item.active .icon-plan .icon-mark {
  background: #eaf3ff;
}
